{
  "plugins": [
    "stylelint-use-logical",
    "./packages/components/scripts/stylelint/no-focus-visible-colored-outline.mjs",
    "./packages/components/scripts/stylelint/no-unguarded-hover-colors.cjs"
  ],
  "overrides": [
    {
      "files": ["**/*.svelte"],
      "customSyntax": "postcss-html"
    }
  ],
  "rules": {
    "declaration-property-value-disallowed-list": {
      "/.*/": [
        "/var\\(\\s*--cinder-(?:color-(?:text|text-muted|surface|border|border-subtle|foreground|foreground-muted|success|danger)|font-size-[a-z0-9-]+|line-height-[a-z0-9-]+|accent-subtle|accent-foreground|focus-ring)(?:\\s*[,)])/"
      ]
    },
    "cinder/no-focus-visible-colored-outline": [
      true,
      {
        "severity": "warning"
      }
    ],
    "cinder/no-unguarded-hover-colors": true,
    "csstools/use-logical": [
      "always",
      {
        "direction": "ltr",
        "except": [
          "top",
          "bottom",
          "left",
          "right",
          "width",
          "min-width",
          "max-width",
          "height",
          "min-height",
          "max-height",
          "margin-top",
          "margin-bottom",
          "padding-top",
          "padding-bottom",
          "border-top",
          "border-bottom",
          "border-top-width",
          "border-bottom-width",
          "border-top-style",
          "border-bottom-style",
          "border-top-color",
          "border-bottom-color",
          "border-top-left-radius",
          "border-top-right-radius",
          "border-bottom-left-radius",
          "border-bottom-right-radius",
          "float",
          "clear",
          "text-align"
        ]
      }
    ]
  },
  "ignoreFiles": [
    "**/node_modules/**",
    "**/dist/**",
    "**/coverage/**",
    "**/build/**",
    "**/.svelte-kit/**"
  ]
}
