{
  "name": "cinder",
  "version": "0.0.1",
  "description": "",
  "license": "MIT",
  "author": "Steve Kinney <hello@stevekinney.net>",
  "sideEffects": [
    "**/*.css"
  ],
  "type": "module",
  "exports": {
    ".": {
      "svelte": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "node": "./dist/server/index.js"
    },
    "./styles": {
      "default": "./src/styles/index.css"
    }
  },
  "main": "./dist/server/index.js",
  "svelte": "./src/index.ts",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src/index.ts",
    "src/components",
    "src/styles",
    "src/utilities",
    "README.md"
  ],
  "scripts": {
    "build": "bun run scripts/build.ts",
    "clean": "rm -rf dist coverage tsconfig.tsbuildinfo",
    "dev": "bun --watch run src/index.ts",
    "format": "prettier --write \"**/*.{ts,tsx,svelte,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,svelte,js,jsx,json,md,css}\"",
    "lint": "oxlint --type-aware --tsconfig ./tsconfig.json",
    "lint:fix": "oxlint --fix --type-aware --tsconfig ./tsconfig.json",
    "prepack": "bun run build",
    "playground": "echo 'Playground lands in Phase 3a.' && exit 0",
    "prepare": "husky",
    "prepublishOnly": "bun run validate && bun run build",
    "start": "bun run src/index.ts",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "typecheck": "tsc --noEmit -p tsconfig.check.json && bunx svelte-check --tsconfig tsconfig.json --threshold error",
    "validate": "bun run lint && bun run typecheck && bun run test && bun run validate:workflow && bun run validate:consumer",
    "validate:consumer": "bun run scripts/validate-consumers.ts",
    "validate:workflow": "bun run scripts/validate-commit-workflow.ts",
    "verify:release-version": "bun run scripts/verify-release-version.ts"
  },
  "lint-staged": {
    "src/**/*.{js,ts,tsx,jsx,mjs,cjs}": [
      "oxlint --fix --type-aware --tsconfig ./tsconfig.json",
      "prettier --write"
    ],
    "scripts/**/*.{js,ts,tsx,jsx,mjs,cjs}": [
      "oxlint --fix",
      "prettier --write"
    ],
    "**/*.svelte": [
      "prettier --write"
    ],
    "**/*.{json,md,css,scss}": [
      "prettier --write"
    ],
    "package.json": [
      "sort-package-json"
    ]
  },
  "dependencies": {
    "change-case": "^5.4.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testing-library/svelte": "^5.2.7",
    "@types/bun": "^1.3.11",
    "chalk": "^5.6.2",
    "happy-dom": "^15.11.7",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.17.0",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-svelte": "^3.3.2",
    "sort-package-json": "^3.6.1",
    "svelte": "~5.55.0",
    "svelte-check": "^4.0.0",
    "svelte2tsx": "^0.7.33",
    "typescript": "^5.9.0"
  },
  "peerDependencies": {
    "svelte": ">=5.55.0 <5.56.0"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
