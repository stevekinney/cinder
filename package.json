{
  "name": "cinder",
  "version": "0.0.1",
  "description": "",
  "license": "MIT",
  "author": "Steve Kinney <hello@stevekinney.net>",
  "sideEffects": [
    "**/*.css"
  ],
  "type": "module",
  "exports": {
    ".": {
      "svelte": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "node": "./dist/server/index.js"
    },
    "./styles": {
      "default": "./src/styles/index.css"
    },
    "./accordion-item": {
      "svelte": "./src/components/accordion-item.svelte",
      "types": "./dist/components/accordion-item.svelte.d.ts"
    },
    "./accordion": {
      "svelte": "./src/components/accordion.svelte",
      "types": "./dist/components/accordion.svelte.d.ts"
    },
    "./alert": {
      "svelte": "./src/components/alert.svelte",
      "types": "./dist/components/alert.svelte.d.ts"
    },
    "./badge": {
      "svelte": "./src/components/badge.svelte",
      "types": "./dist/components/badge.svelte.d.ts"
    },
    "./button": {
      "svelte": "./src/components/button.svelte",
      "types": "./dist/components/button.svelte.d.ts"
    },
    "./card": {
      "svelte": "./src/components/card.svelte",
      "types": "./dist/components/card.svelte.d.ts"
    },
    "./data-list": {
      "svelte": "./src/components/data-list.svelte",
      "types": "./dist/components/data-list.svelte.d.ts"
    },
    "./dropdown": {
      "svelte": "./src/components/dropdown.svelte",
      "types": "./dist/components/dropdown.svelte.d.ts"
    },
    "./empty-state": {
      "svelte": "./src/components/empty-state.svelte",
      "types": "./dist/components/empty-state.svelte.d.ts"
    },
    "./input": {
      "svelte": "./src/components/input.svelte",
      "types": "./dist/components/input.svelte.d.ts"
    },
    "./modal": {
      "svelte": "./src/components/modal.svelte",
      "types": "./dist/components/modal.svelte.d.ts"
    },
    "./navigation-bar": {
      "svelte": "./src/components/navigation-bar.svelte",
      "types": "./dist/components/navigation-bar.svelte.d.ts"
    },
    "./navigation-item": {
      "svelte": "./src/components/navigation-item.svelte",
      "types": "./dist/components/navigation-item.svelte.d.ts"
    },
    "./page-layout": {
      "svelte": "./src/components/page-layout.svelte",
      "types": "./dist/components/page-layout.svelte.d.ts"
    },
    "./pagination": {
      "svelte": "./src/components/pagination.svelte",
      "types": "./dist/components/pagination.svelte.d.ts"
    },
    "./select": {
      "svelte": "./src/components/select.svelte",
      "types": "./dist/components/select.svelte.d.ts"
    },
    "./skeleton": {
      "svelte": "./src/components/skeleton.svelte",
      "types": "./dist/components/skeleton.svelte.d.ts"
    },
    "./spinner": {
      "svelte": "./src/components/spinner.svelte",
      "types": "./dist/components/spinner.svelte.d.ts"
    },
    "./textarea": {
      "svelte": "./src/components/textarea.svelte",
      "types": "./dist/components/textarea.svelte.d.ts"
    },
    "./toggle": {
      "svelte": "./src/components/toggle.svelte",
      "types": "./dist/components/toggle.svelte.d.ts"
    },
    "./tooltip": {
      "svelte": "./src/components/tooltip.svelte",
      "types": "./dist/components/tooltip.svelte.d.ts"
    }
  },
  "main": "./dist/server/index.js",
  "svelte": "./src/index.ts",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src/index.ts",
    "src/components/**/*.svelte",
    "src/styles/**/*.css",
    "src/utilities/class-names.ts",
    "src/utilities/format-date.ts",
    "src/utilities/format-duration.ts",
    "src/utilities/format-number.ts",
    "src/utilities/truncate.ts",
    "README.md"
  ],
  "scripts": {
    "build": "bun run scripts/build.ts",
    "clean": "rm -rf dist coverage tsconfig.tsbuildinfo cinder-*.tgz tmp fixtures/node-consumer/node_modules fixtures/node-consumer/dist fixtures/sveltekit-consumer/node_modules fixtures/sveltekit-consumer/.svelte-kit fixtures/sveltekit-consumer/build",
    "dev": "echo 'No dev server in Phase 1. Use `bun run test --watch` for component feedback, or wait for the playground in Phase 3a.' && exit 1",
    "exports:check": "bun run scripts/generate-exports.ts --check",
    "exports:generate": "bun run scripts/generate-exports.ts",
    "format": "prettier --write \"**/*.{ts,tsx,svelte,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,svelte,js,jsx,json,md,css}\"",
    "lint": "oxlint --type-aware --tsconfig ./tsconfig.json",
    "lint:fix": "oxlint --fix --type-aware --tsconfig ./tsconfig.json",
    "prepack": "bun run build",
    "playground": "bun --hot run scripts/playground/server.ts",
    "prepare": "husky",
    "prepublishOnly": "bun run validate && bun run build",
    "start": "echo 'No direct runtime start entrypoint is configured for this package.' && exit 1",
    "test": "TZ=UTC LANG=en_US.UTF-8 bun test --conditions browser",
    "test:coverage": "TZ=UTC LANG=en_US.UTF-8 bun test --conditions browser --coverage",
    "typecheck": "tsc --noEmit -p tsconfig.check.json && bunx svelte-check --tsconfig tsconfig.json --threshold error",
    "validate": "bun run lint && bun run typecheck && bun run test && bun run validate:workflow && bun run validate:consumer",
    "validate:consumer": "bun run scripts/validate-consumers.ts",
    "validate:playground": "bun run scripts/playground/validate-playground.ts",
    "validate:workflow": "bun run scripts/validate-commit-workflow.ts",
    "verify:release-version": "bun run scripts/verify-release-version.ts"
  },
  "lint-staged": {
    "src/**/*.{js,ts,tsx,jsx,mjs,cjs}": [
      "oxlint --fix --type-aware --tsconfig ./tsconfig.json",
      "prettier --write"
    ],
    "scripts/**/*.{js,ts,tsx,jsx,mjs,cjs}": [
      "oxlint --fix",
      "prettier --write"
    ],
    "**/*.svelte": [
      "prettier --write"
    ],
    "**/*.{json,md,css,scss}": [
      "prettier --write"
    ],
    "package.json": [
      "sort-package-json"
    ]
  },
  "dependencies": {
    "esm-env": "^1.2.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.2.7",
    "@types/bun": "^1.3.11",
    "chalk": "^5.6.2",
    "change-case": "^5.4.4",
    "happy-dom": "^15.11.7",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.17.0",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-svelte": "^3.3.2",
    "sort-package-json": "^3.6.1",
    "svelte": "~5.55.0",
    "svelte-check": "^4.0.0",
    "svelte2tsx": "^0.7.33",
    "typescript": "^5.9.0"
  },
  "peerDependencies": {
    "svelte": ">=5.55.0 <5.56.0"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
