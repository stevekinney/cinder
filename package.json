{
  "name": "cinder-workspace",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/components",
    "packages/diff",
    "packages/markdown",
    "packages/playground"
  ],
  "scripts": {
    "build": "bun run --filter=cinder build",
    "clean": "bun run --filter='*' clean",
    "format": "prettier --write \"**/*.{ts,tsx,svelte,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,svelte,js,jsx,json,md,css}\"",
    "lint": "bun run --filter='*' lint",
    "lint:fix": "bun run --filter='*' lint:fix",
    "playground": "bun run --filter='@cinder/playground' dev",
    "prepare": "husky",
    "test": "TZ=UTC LANG=en_US.UTF-8 bun test --conditions browser",
    "typecheck": "bun run --filter='*' typecheck",
    "validate": "bun run --filter='*' validate && bun run --filter=cinder validate:consumer",
    "validate:consumer": "bun run --filter=cinder validate:consumer",
    "validate:playground": "bun run --filter='@cinder/playground' validate"
  },
  "lint-staged": {
    "packages/components/src/**/*.{js,ts,tsx,jsx,mjs,cjs}": [
      "oxlint --fix --type-aware --tsconfig ./packages/components/tsconfig.json",
      "prettier --write"
    ],
    "packages/components/scripts/**/*.{js,ts,tsx,jsx,mjs,cjs}": [
      "oxlint --fix",
      "prettier --write"
    ],
    "packages/diff/**/*.{js,ts,tsx,jsx,mjs,cjs}": [
      "oxlint --fix --type-aware --tsconfig ./packages/diff/tsconfig.json",
      "prettier --write"
    ],
    "packages/markdown/**/*.{js,ts,tsx,jsx,mjs,cjs}": [
      "oxlint --fix --type-aware --tsconfig ./packages/markdown/tsconfig.json",
      "prettier --write"
    ],
    "packages/playground/src/**/*.{js,ts,tsx,jsx,mjs,cjs}": [
      "oxlint --fix",
      "prettier --write"
    ],
    "**/*.svelte": [
      "prettier --write"
    ],
    "**/*.{json,md,css,scss}": [
      "prettier --write"
    ],
    "package.json": [
      "sort-package-json"
    ]
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-svelte": "^3.3.2",
    "sort-package-json": "^3.6.1"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
