{
  "name": "cinder-workspace",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/components",
    "packages/commentary",
    "packages/diff",
    "packages/editor",
    "packages/markdown",
    "packages/playground",
    "packages/testing"
  ],
  "scripts": {
    "build": "bun run --filter=cinder build",
    "changeset": "changeset",
    "changeset:publish": "changeset publish",
    "changeset:publish:dry": "bun run --filter=cinder build && cd packages/components && npm publish --dry-run",
    "changeset:version": "changeset version",
    "clean": "bun run --filter='*' clean",
    "dev": "bun run --filter='@cinder/playground' dev",
    "format": "prettier --write \"**/*.{ts,tsx,svelte,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,svelte,js,jsx,json,md,css}\"",
    "lint": "bun run --filter='*' lint && stylelint \"packages/**/src/**/*.{css,svelte}\"",
    "lint:fix": "bun run --filter='*' lint:fix && stylelint \"packages/**/src/**/*.{css,svelte}\" --fix",
    "playground": "bun run --filter='@cinder/playground' dev",
    "prepare": "husky",
    "test": "bun run --filter='*' test",
    "test:browser": "bun run --filter='@cinder/testing' test:playwright",
    "test:browser:headed": "bun run --filter='@cinder/testing' test:playwright:headed",
    "test:browser:install": "bun run --filter='@cinder/testing' install-browsers",
    "test:browser:ui": "bun run --filter='@cinder/testing' test:playwright:ui",
    "typecheck": "bun run --filter='*' typecheck",
    "validate": "bun run --filter='*' validate && bun run --filter=cinder validate:consumer",
    "validate:consumer": "bun run --filter=cinder validate:consumer",
    "validate:playground": "bun run --filter='@cinder/playground' validate"
  },
  "lint-staged": {
    "packages/components/src/**/*.{js,ts,tsx,jsx,mjs,cjs}": [
      "oxlint --fix --type-aware --tsconfig ./packages/components/tsconfig.json",
      "prettier --write"
    ],
    "packages/components/scripts/**/*.{js,ts,tsx,jsx,mjs,cjs}": [
      "oxlint --fix",
      "prettier --write"
    ],
    "packages/commentary/**/*.{js,ts,tsx,jsx,mjs,cjs}": [
      "oxlint --fix --type-aware --tsconfig ./packages/commentary/tsconfig.json",
      "prettier --write"
    ],
    "packages/diff/**/*.{js,ts,tsx,jsx,mjs,cjs}": [
      "oxlint --fix --type-aware --tsconfig ./packages/diff/tsconfig.json",
      "prettier --write"
    ],
    "packages/editor/**/*.{js,ts,tsx,jsx,mjs,cjs}": [
      "oxlint --fix --type-aware --tsconfig ./packages/editor/tsconfig.json",
      "prettier --write"
    ],
    "packages/markdown/**/*.{js,ts,tsx,jsx,mjs,cjs}": [
      "oxlint --fix --type-aware --tsconfig ./packages/markdown/tsconfig.json",
      "prettier --write"
    ],
    "packages/playground/src/**/*.{js,ts,tsx,jsx,mjs,cjs}": [
      "oxlint --fix --type-aware --tsconfig ./packages/playground/tsconfig.json",
      "prettier --write"
    ],
    "packages/testing/**/*.{js,ts,tsx,jsx,mjs,cjs}": [
      "oxlint --fix",
      "prettier --write"
    ],
    "packages/**/src/**/*.{svelte,css}": [
      "stylelint --fix",
      "prettier --write"
    ],
    "**/*.{json,md,scss}": [
      "prettier --write"
    ],
    "package.json": [
      "sort-package-json"
    ]
  },
  "devDependencies": {
    "@changesets/changelog-github": "0.7.0",
    "@changesets/cli": "2.31.0",
    "@types/bun": "1.3.14",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss-html": "^1.8.1",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-svelte": "^3.3.2",
    "sort-package-json": "^3.6.1",
    "stylelint": "^17.11.1",
    "stylelint-use-logical": "^2.1.3"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
