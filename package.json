{
  "name": "cinder",
  "version": "0.0.1",
  "description": "",
  "license": "MIT",
  "author": "Steve Kinney <hello@stevekinney.net>",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "bun": "./dist/index.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun run scripts/build.ts",
    "clean": "rm -rf dist coverage tsconfig.tsbuildinfo",
    "dev": "bun --watch run src/index.ts",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "lint": "oxlint --type-aware --tsconfig ./tsconfig.json",
    "lint:fix": "oxlint --fix --type-aware --tsconfig ./tsconfig.json",
    "prepack": "bun run build",
    "prepare": "husky",
    "prepublishOnly": "bun run validate && bun run build",
    "start": "bun run src/index.ts",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "typecheck": "tsc --noEmit",
    "validate": "bun run lint && bun run typecheck && bun run test",
    "verify:release-version": "bun run scripts/verify-release-version.ts"
  },
  "lint-staged": {
    "src/**/*.{js,ts,tsx,jsx,mjs,cjs}": [
      "oxlint --fix --type-aware --tsconfig ./tsconfig.json",
      "prettier --write"
    ],
    "scripts/**/*.{js,ts,tsx,jsx,mjs,cjs}": [
      "oxlint --fix",
      "prettier --write"
    ],
    "**/*.{json,md,css,scss}": [
      "prettier --write"
    ],
    "package.json": [
      "sort-package-json"
    ]
  },
  "dependencies": {
    "change-case": "^5.4.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "chalk": "^5.6.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.17.0",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "sort-package-json": "^3.6.1"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
