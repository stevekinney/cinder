{
  "$schema": "https://turborepo.dev/schema.json",
  "globalDependencies": [
    "tsconfig.json",
    "tsconfig.base.json",
    ".oxlintrc.json",
    "packages/components/scripts/check-coverage-ratchet.ts"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test:coverage": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "@cinder/playground#typecheck": {
      "dependsOn": [],
      "outputs": []
    },
    "@lostgradient/chat#typecheck": {
      "dependsOn": [],
      "outputs": []
    },
    "lint": {
      "dependsOn": [],
      "outputs": []
    },
    "validate": {
      "dependsOn": ["^build", "build"],
      "outputs": [],
      "cache": false
    }
  }
}
