{
  "name": "@cinder-fixture/resolver-matrix",
  "version": "0.0.0",
  "private": true,
  "description": "Resolver matrix fixture: mirrors the cinder exports shape for a single component (`button`) so we can validate TypeScript `nodenext` and `bundler` module resolution without touching the published package.json.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./src/index.ts",
      "node": "./dist/server/index.js",
      "svelte": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json",
    "./button": {
      "types": "./dist/components/button/index.d.ts",
      "browser": "./src/components/button/index.ts",
      "node": "./dist/server/components/button/index.js",
      "svelte": "./src/components/button/index.ts",
      "default": "./dist/components/button/index.js"
    },
    "./styles/guard": {
      "types": "./dist/styles/base-guard.d.ts",
      "browser": "./src/styles/base-guard.ts",
      "node": "./dist/server/styles/base-guard.js",
      "svelte": "./src/styles/base-guard.ts",
      "default": "./dist/styles/base-guard.js"
    }
  }
}
