{
  "$schema": "../../schemas/examples.schema.json",
  "component": "drawer",
  "import": "cinder/drawer",
  "examples": [
    {
      "id": "basic",
      "title": "Basic drawer",
      "description": "An edge-anchored slide-in panel with controls for side, size, and triggerRef.",
      "code": "<script lang=\"ts\">\n  import { Button } from 'cinder/button';\n  import { Drawer } from 'cinder/drawer';\n  import type { DrawerSide, DrawerSize } from 'cinder/drawer';\n  let open = $state(false);\n  let triggerRef: HTMLElement | null = $state(null);\n  let side = $state<DrawerSide>('right');\n  let size = $state<DrawerSize>('md');\n  let useTriggerRef = $state(true);\n</script>\n\n<div style=\"display: flex; flex-direction: column; gap: 1rem; max-width: 32rem;\">\n  <div style=\"display: flex; flex-wrap: wrap; gap: 1rem; align-items: flex-end;\">\n    <label style=\"display: flex; flex-direction: column; gap: 0.25rem; font-size: 0.875rem;\">\n      Side\n      <select\n        value={side}\n        onchange={(e) => (side = (e.currentTarget as HTMLSelectElement).value as DrawerSide)}\n        style=\"padding: 0.25rem 0.5rem; border-radius: 0.375rem; border: 1px solid var(--cinder-border); background-color: var(--cinder-surface-inset); color: var(--cinder-text);\"\n      >\n        <option value=\"right\">right</option>\n        <option value=\"left\">left</option>\n      </select>\n    </label>\n\n    <label style=\"display: flex; flex-direction: column; gap: 0.25rem; font-size: 0.875rem;\">\n      Size\n      <select\n        value={size}\n        onchange={(e) => (size = (e.currentTarget as HTMLSelectElement).value as DrawerSize)}\n        style=\"padding: 0.25rem 0.5rem; border-radius: 0.375rem; border: 1px solid var(--cinder-border); background-color: var(--cinder-surface-inset); color: var(--cinder-text);\"\n      >\n        <option value=\"sm\">sm</option>\n        <option value=\"md\">md</option>\n        <option value=\"lg\">lg</option>\n        <option value=\"xl\">xl</option>\n      </select>\n    </label>\n\n    <label\n      style=\"display: flex; align-items: center; gap: 0.5rem; font-size: 0.875rem; cursor: pointer;\"\n    >\n      <input type=\"checkbox\" bind:checked={useTriggerRef} />\n      Use triggerRef\n    </label>\n  </div>\n\n  <Button\n    label=\"Open drawer\"\n    onclick={(event) => {\n      triggerRef = useTriggerRef ? event.currentTarget : null;\n      open = true;\n    }}\n  />\n</div>\n\n<Drawer bind:open {side} {size} title=\"Drawer panel\" triggerRef={useTriggerRef ? triggerRef : null}>\n  <p>This is the drawer body. You can put any content here.</p>\n  <p>Current settings: side={side}, size={size}.</p>\n\n  {#snippet footer()}\n    <div style=\"display: flex; gap: 0.5rem;\">\n      <Button variant=\"secondary\" label=\"Cancel\" onclick={() => (open = false)} />\n      <Button label=\"Confirm\" onclick={() => (open = false)} />\n    </div>\n  {/snippet}\n</Drawer>\n"
    },
    {
      "id": "overflowing",
      "title": "Overflowing drawer",
      "description": "A side drawer with a scrollable body.",
      "code": "<script lang=\"ts\">\n  import { Button } from 'cinder/button';\n  import { Drawer } from 'cinder/drawer';\n\n  let open = $state(false);\n  let triggerRef: HTMLElement | null = $state(null);\n\n  const filters = Array.from({ length: 30 }, (_, index) => ({\n    id: `filter-${index + 1}`,\n    label: `Filter group ${index + 1}`,\n  }));\n</script>\n\n<Button\n  label=\"Open drawer\"\n  onclick={(event) => {\n    triggerRef = event.currentTarget as HTMLElement;\n    open = true;\n  }}\n/>\n\n<Drawer bind:open title=\"Filters\" {triggerRef}>\n  <div style=\"display: grid; gap: 0.75rem;\">\n    {#each filters as filter (filter.id)}\n      <label\n        style=\"display: flex; align-items: center; gap: 0.5rem; color: var(--cinder-text-muted);\"\n      >\n        <input type=\"checkbox\" />\n        {filter.label}\n      </label>\n    {/each}\n  </div>\n\n  {#snippet footer()}\n    <Button variant=\"secondary\" label=\"Cancel\" onclick={() => (open = false)} />\n    <Button label=\"Apply\" onclick={() => (open = false)} />\n  {/snippet}\n</Drawer>\n"
    }
  ]
}
