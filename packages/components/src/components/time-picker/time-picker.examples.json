{
  "$schema": "../../schemas/examples.schema.json",
  "component": "time-picker",
  "import": "cinder/time-picker",
  "examples": [
    {
      "id": "basic",
      "title": "Basic time picker",
      "description": "Choose a time with direct input or the popover list.",
      "code": "<script lang=\"ts\">\n  import { TimePicker } from 'cinder';\n\n  let value = $state('09:30');\n</script>\n\n<div style=\"max-width: 18rem;\">\n  <TimePicker id=\"appointment-time\" bind:value label=\"Appointment time\" />\n  <p>Selected: {value || 'none'}</p>\n</div>\n"
    },
    {
      "id": "locales",
      "title": "Locale hour cycles",
      "description": "Compare how the picker presents the same time across locales.",
      "code": "<script lang=\"ts\">\n  import { TimePicker } from 'cinder';\n\n  let usValue = $state('13:15');\n  let deValue = $state('13:15');\n  let jaValue = $state('13:15');\n</script>\n\n<div style=\"display: grid; gap: 1rem; max-width: 20rem;\">\n  <TimePicker id=\"locale-us\" bind:value={usValue} label=\"United States\" locale=\"en-US\" />\n  <TimePicker id=\"locale-de\" bind:value={deValue} label=\"Germany\" locale=\"de-DE\" />\n  <TimePicker id=\"locale-ja\" bind:value={jaValue} label=\"Japan\" locale=\"ja-JP\" />\n</div>\n"
    },
    {
      "id": "min-max",
      "title": "Constrained range",
      "description": "Limit selections to a valid time window with min and max.",
      "code": "<script lang=\"ts\">\n  import { TimePicker } from 'cinder';\n\n  let value = $state('09:30');\n</script>\n\n<div style=\"max-width: 18rem;\">\n  <TimePicker\n    id=\"office-hours\"\n    bind:value\n    label=\"Office hours\"\n    min=\"09:00\"\n    max=\"17:00\"\n    description=\"Choose a time during office hours.\"\n  />\n  <p>Selected: {value || 'none'}</p>\n</div>\n"
    },
    {
      "id": "twelve-hour",
      "title": "Twelve-hour display",
      "description": "Render a picker with AM and PM selection controls.",
      "code": "<script lang=\"ts\">\n  import { TimePicker } from 'cinder';\n\n  let value = $state('13:15');\n</script>\n\n<div style=\"max-width: 18rem;\">\n  <TimePicker\n    id=\"follow-up-time\"\n    bind:value\n    label=\"Follow-up time\"\n    hourCycle=\"h12\"\n    locale=\"en-US\"\n  />\n  <p>Selected: {value || 'none'}</p>\n</div>\n"
    },
    {
      "id": "with-seconds",
      "title": "Second precision",
      "description": "Enable second-level precision for time entry and selection.",
      "code": "<script lang=\"ts\">\n  import { TimePicker } from 'cinder';\n\n  let value = $state('09:30:00');\n</script>\n\n<div style=\"max-width: 18rem;\">\n  <TimePicker id=\"precise-time\" bind:value label=\"Precise time\" seconds step={1} />\n  <p>Selected: {value || 'none'}</p>\n</div>\n"
    }
  ]
}
