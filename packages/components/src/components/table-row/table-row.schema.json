{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "class": {
      "type": "string",
      "description": "Additional class names merged with `.cinder-table__row`."
    },
    "selected": {
      "type": "boolean"
    },
    "selectionLabel": {
      "type": "string"
    },
    "selectionDisabled": {
      "type": "boolean"
    }
  },
  "additionalProperties": false,
  "metadata": {
    "unsupportedProps": [
      {
        "name": "children",
        "reason": "function-or-snippet"
      },
      {
        "name": "onSelectedChange",
        "reason": "function-or-snippet"
      }
    ]
  }
}
