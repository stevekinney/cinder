{
  "$schema": "../../schemas/examples.schema.json",
  "component": "chip",
  "import": "cinder/chip",
  "examples": [
    {
      "id": "disabled",
      "title": "Chip disabled states",
      "description": "Disabled toggle and disabled removable chip.",
      "code": "<script lang=\"ts\">\n  import { Chip } from 'cinder/chip';\n</script>\n\n<div class=\"example-preview-row\">\n  <Chip mode=\"toggle\" label=\"Disabled toggle\" pressed={false} disabled />\n  <Chip mode=\"removable\" label=\"Disabled removable\" disabled />\n</div>\n"
    },
    {
      "id": "modes",
      "title": "Chip modes",
      "description": "Display, toggle, and removable chip modes.",
      "code": "<script lang=\"ts\">\n  import { Chip } from 'cinder/chip';\n  let pressed = $state(false);\n  let tags = $state(['JavaScript', 'TypeScript', 'Svelte']);\n</script>\n\n<!-- Manual check: click anywhere on the chip label text — onremove must not fire. -->\n<div class=\"example-preview-row\">\n  <Chip label=\"Display\" />\n\n  <Chip\n    mode=\"toggle\"\n    label={pressed ? 'Active' : 'Inactive'}\n    {pressed}\n    onpressedchange={(value) => {\n      pressed = value;\n    }}\n  />\n\n  {#each tags as tag (tag)}\n    <Chip\n      mode=\"removable\"\n      label={tag}\n      onremove={() => {\n        tags = tags.filter((t) => t !== tag);\n      }}\n    />\n  {/each}\n</div>\n"
    },
    {
      "id": "variants",
      "title": "Chip variants",
      "description": "All six semantic variant styles in display mode.",
      "code": "<script lang=\"ts\">\n  import { Chip } from 'cinder/chip';\n</script>\n\n<div class=\"example-preview-row\">\n  <Chip label=\"Neutral\" variant=\"neutral\" />\n  <Chip label=\"Success\" variant=\"success\" />\n  <Chip label=\"Warning\" variant=\"warning\" />\n  <Chip label=\"Danger\" variant=\"danger\" />\n  <Chip label=\"Info\" variant=\"info\" />\n  <Chip label=\"Accent\" variant=\"accent\" />\n</div>\n"
    }
  ]
}
