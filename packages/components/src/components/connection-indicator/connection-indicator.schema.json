{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "state": {
      "enum": ["connected", "connecting", "disconnected", "error"],
      "description": "Current connection state."
    },
    "label": {
      "type": "string",
      "description": "Optional override for the visible label. Defaults derived from `state`."
    },
    "class": {
      "type": "string",
      "description": "Additional class names merged with `.cinder-connection-indicator`."
    }
  },
  "additionalProperties": false,
  "required": ["state"]
}
