{
  "$schema": "../../schemas/examples.schema.json",
  "component": "connection-indicator",
  "import": "@lostgradient/cinder/connection-indicator",
  "examples": [
    {
      "id": "basic",
      "title": "Basic connection indicator",
      "description": "Live-status pill showing the current realtime channel state.",
      "code": "<script lang=\"ts\">\n  import { ConnectionIndicator } from '@lostgradient/cinder/connection-indicator';\n  import type { ConnectionState } from '@lostgradient/cinder/connection-indicator';\n\n  const states: ConnectionState[] = ['connected', 'connecting', 'disconnected', 'error'];\n</script>\n\n<div style=\"display: flex; flex-direction: column; gap: 0.5rem;\">\n  {#each states as state}\n    <ConnectionIndicator {state} />\n  {/each}\n</div>\n"
    }
  ]
}
