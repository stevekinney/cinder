{
  "$schema": "../../schemas/examples.schema.json",
  "component": "toggle",
  "import": "cinder/toggle",
  "examples": [
    {
      "id": "basic",
      "title": "Basic toggle",
      "description": "Switch using the WAI-ARIA switch pattern (aria-checked reflects state).",
      "code": "<script lang=\"ts\">\n  import { Toggle } from 'cinder/toggle';\n  let emailNotifications = $state(false);\n</script>\n\n<Toggle id=\"email-notifications\" bind:checked={emailNotifications} label=\"Email notifications\" />\n<p style=\"margin-top: 0.5rem; color: var(--cinder-text-muted);\">\n  {emailNotifications ? 'Notifications enabled' : 'Notifications disabled'}\n</p>\n"
    },
    {
      "id": "group",
      "title": "Multiple switches",
      "description": "Several independent on/off settings inside a fieldset/legend, each with a visible adjacent label.",
      "code": "<script lang=\"ts\">\n  import { Toggle } from 'cinder/toggle';\n  let emailNotifications = $state(true);\n  let darkMode = $state(false);\n  let autoSave = $state(true);\n</script>\n\n<fieldset\n  style=\"display: flex; flex-direction: column; gap: 0.6rem; padding: 0.75rem 1rem; border: 1px solid var(--cinder-border-muted); border-radius: 0.5rem;\"\n>\n  <legend style=\"padding: 0 0.25rem; font-weight: 600;\">Account preferences</legend>\n\n  <div style=\"display: flex; align-items: center; gap: 0.75rem;\">\n    <Toggle id=\"pref-email\" bind:checked={emailNotifications} label=\"Email notifications\" />\n    <span aria-hidden=\"true\">Email notifications</span>\n  </div>\n\n  <div style=\"display: flex; align-items: center; gap: 0.75rem;\">\n    <Toggle id=\"pref-dark\" bind:checked={darkMode} label=\"Dark mode\" />\n    <span aria-hidden=\"true\">Dark mode</span>\n  </div>\n\n  <div style=\"display: flex; align-items: center; gap: 0.75rem;\">\n    <Toggle id=\"pref-autosave\" bind:checked={autoSave} label=\"Auto-save drafts\" />\n    <span aria-hidden=\"true\">Auto-save drafts</span>\n  </div>\n</fieldset>\n"
    }
  ]
}
