{
  "$schema": "../../schemas/examples.schema.json",
  "component": "popover",
  "import": "@lostgradient/cinder/popover",
  "examples": [
    {
      "id": "basic",
      "title": "Basic popover",
      "description": "A button trigger that opens a floating panel. The panel preserves focus on the trigger — use focusManagement=\"panel\" when the panel contains a form or search input that needs immediate keyboard access.",
      "code": "<script lang=\"ts\">\n  import { Button } from '@lostgradient/cinder/button';\n  import { Popover } from '@lostgradient/cinder/popover';\n\n  const popoverHeadingId = 'account-settings-popover-title';\n\n  let open = $state(false);\n</script>\n\n<!--\n  align-items: flex-start prevents the Popover (and its trigger Button) from\n  stretching to the full container width. Without it, the trigger Button becomes\n  a wide bar and the panel arrow no longer aligns to the trigger center.\n-->\n<div\n  style=\"padding: 4rem; display: flex; flex-direction: column; align-items: flex-start; gap: 1rem;\"\n>\n  <!--\n    focusManagement=\"preserve\" keeps focus on the trigger after open.\n    Use the default \"panel\" when the panel contains a form or requires\n    immediate keyboard interaction (e.g. a search input or date picker).\n  -->\n  <Popover bind:open ariaLabelledby={popoverHeadingId} showArrow focusManagement=\"preserve\">\n    {#snippet trigger()}\n      <Button label=\"Account settings\" onclick={() => (open = !open)} />\n    {/snippet}\n\n    <div\n      style=\"display: flex; flex-direction: column; gap: var(--cinder-space-2); min-width: 14rem;\"\n    >\n      <h2\n        id={popoverHeadingId}\n        style=\"margin: 0; font-size: var(--cinder-text-sm); font-weight: var(--cinder-font-semibold); color: var(--cinder-text);\"\n      >\n        Account settings\n      </h2>\n      <p style=\"margin: 0; font-size: var(--cinder-text-xs); color: var(--cinder-text-muted);\">\n        Edit your profile, manage billing, or sign out.\n      </p>\n      <Button variant=\"secondary\" label=\"Edit profile\" onclick={() => (open = false)} />\n      <Button variant=\"ghost-danger\" label=\"Sign out\" onclick={() => (open = false)} />\n    </div>\n  </Popover>\n</div>\n"
    },
    {
      "id": "transformed-ancestor",
      "title": "Transformed ancestor anchoring",
      "description": "Scroll a transformed preview shell, then open the popover to verify fixed-position Floating UI anchoring.",
      "code": "<script lang=\"ts\">\n  import { Popover } from '@lostgradient/cinder/popover';\n\n  let open = $state(false);\n  let triggerElement: HTMLButtonElement | null = $state(null);\n\n  function togglePopover() {\n    open = !open;\n  }\n</script>\n\n<div data-testid=\"transformed-ancestor-example\" style=\"display: grid; gap: 1rem; max-width: 40rem;\">\n  <p style=\"margin: 0;\">\n    This fixture nests the trigger inside a transformed card and a scrollable inner viewport. The\n    popover should still align after the scroll container moves away from zero.\n  </p>\n\n  <div\n    data-testid=\"transformed-shell\"\n    style=\"transform: translate3d(32px, 0, 0) scale(0.98); transform-origin: top left; padding: 1rem; border-radius: 1rem; background: var(--cinder-surface-raised); border: 1px solid var(--cinder-border);\"\n  >\n    <div\n      data-testid=\"transformed-scroll-container\"\n      style=\"overflow: auto; width: 28rem; height: 18rem; padding: 1.5rem; border-radius: 0.75rem; background: var(--cinder-surface);\"\n    >\n      <div style=\"width: 48rem; height: 30rem; padding-top: 10rem; padding-left: 12rem;\">\n        <button\n          type=\"button\"\n          bind:this={triggerElement}\n          data-testid=\"transformed-popover-trigger\"\n          onclick={togglePopover}\n        >\n          Toggle anchored popover\n        </button>\n\n        <Popover\n          bind:open\n          triggerRef={triggerElement}\n          placement=\"bottom\"\n          label=\"Transformed ancestor popover\"\n          class=\"transformed-ancestor-popover-panel\"\n        >\n          <div style=\"display: grid; gap: 0.5rem; min-width: 14rem;\">\n            <strong>Anchored popover</strong>\n            <p style=\"margin: 0; color: var(--cinder-text-muted);\">\n              This panel should remain attached to the trigger after scrolling the transformed\n              container.\n            </p>\n          </div>\n        </Popover>\n      </div>\n    </div>\n  </div>\n</div>\n"
    }
  ]
}
