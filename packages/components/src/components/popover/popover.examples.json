{
  "$schema": "../../schemas/examples.schema.json",
  "component": "popover",
  "import": "cinder/popover",
  "examples": [
    {
      "id": "basic",
      "title": "Basic popover",
      "description": "A button trigger that opens an interactive floating panel. Anchor positioning via floating-ui; focus moves into the panel on open and restores to the trigger on close.",
      "code": "<script lang=\"ts\">\n  import { Popover } from 'cinder/popover';\n  let open = $state(false);\n  let triggerEl: HTMLButtonElement | null = $state(null);\n</script>\n\n<div style=\"padding: 4rem; display: flex; flex-direction: column; gap: 1rem;\">\n  <button type=\"button\" bind:this={triggerEl} onclick={() => (open = !open)}>\n    Toggle popover\n  </button>\n\n  <Popover bind:open triggerRef={triggerEl} label=\"Account settings\" showArrow>\n    <div style=\"display: flex; flex-direction: column; gap: 0.5rem; min-width: 14rem;\">\n      <strong>Account</strong>\n      <p style=\"margin: 0; font-size: 0.875rem; color: var(--cinder-text-muted, currentColor);\">\n        Edit your profile, manage billing, or sign out.\n      </p>\n      <button type=\"button\" onclick={() => (open = false)}>Edit profile</button>\n      <button type=\"button\" onclick={() => (open = false)}>Sign out</button>\n    </div>\n  </Popover>\n</div>\n"
    },
    {
      "id": "transformed-ancestor",
      "title": "Transformed ancestor anchoring",
      "description": "Scroll a transformed preview shell, then open the popover to verify fixed-position Floating UI anchoring.",
      "code": "<script lang=\"ts\">\n  import { Popover } from 'cinder/popover';\n\n  let open = $state(false);\n  let triggerElement: HTMLButtonElement | null = $state(null);\n\n  function togglePopover() {\n    open = !open;\n  }\n</script>\n\n<div\n  data-testid=\"transformed-ancestor-example\"\n  style=\"display: grid; gap: 1rem; max-width: 40rem;\"\n>\n  <p style=\"margin: 0;\">\n    This fixture nests the trigger inside a transformed card and a scrollable inner viewport. The\n    popover should still align after the scroll container moves away from zero.\n  </p>\n\n  <div\n    data-testid=\"transformed-shell\"\n    style=\"transform: translate3d(32px, 0, 0) scale(0.98); transform-origin: top left; padding: 1rem; border-radius: 1rem; background: var(--cinder-surface-raised); border: 1px solid var(--cinder-border);\"\n  >\n    <div\n      data-testid=\"transformed-scroll-container\"\n      style=\"overflow: auto; width: 28rem; height: 18rem; padding: 1.5rem; border-radius: 0.75rem; background: var(--cinder-surface);\"\n    >\n      <div style=\"width: 48rem; height: 30rem; padding-top: 10rem; padding-left: 12rem;\">\n        <button\n          type=\"button\"\n          bind:this={triggerElement}\n          data-testid=\"transformed-popover-trigger\"\n          onclick={togglePopover}\n        >\n          Toggle anchored popover\n        </button>\n\n        <Popover\n          bind:open\n          triggerRef={triggerElement}\n          placement=\"bottom\"\n          label=\"Transformed ancestor popover\"\n          class=\"transformed-ancestor-popover-panel\"\n        >\n          <div style=\"display: grid; gap: 0.5rem; min-width: 14rem;\">\n            <strong>Anchored popover</strong>\n            <p style=\"margin: 0; color: var(--cinder-text-muted);\">\n              This panel should remain attached to the trigger after scrolling the transformed\n              container.\n            </p>\n          </div>\n        </Popover>\n      </div>\n    </div>\n  </div>\n</div>\n"
    }
  ]
}
