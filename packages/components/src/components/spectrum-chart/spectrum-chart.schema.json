{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "label": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "height": {
      "type": "number"
    },
    "loading": {
      "type": "boolean"
    },
    "dataTableVisibility": {
      "enum": ["screen-reader-only", "visible", "hidden"]
    },
    "dataTableCaption": {
      "type": "string"
    },
    "class": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "required": ["label"],
  "metadata": {
    "unsupportedProps": [
      {
        "name": "bins",
        "reason": "unknown-shape"
      }
    ]
  }
}
