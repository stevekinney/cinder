{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "label": {
      "type": "string",
      "description": "Visible label rendered in a `<label>` element associated via `for`."
    },
    "description": {
      "type": "string",
      "description": "Helper text rendered as `<p id=\"{id}-description\">`, wired via aria-describedby."
    }
  },
  "additionalProperties": false,
  "required": ["label"],
  "metadata": {
    "unsupportedProps": [
      {
        "name": "class",
        "reason": "unknown-shape"
      }
    ]
  }
}
