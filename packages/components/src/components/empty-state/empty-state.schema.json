{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "class": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "required": ["title"],
  "metadata": {
    "unsupportedProps": [
      {
        "name": "action",
        "reason": "function-or-snippet"
      },
      {
        "name": "icon",
        "reason": "function-or-snippet"
      }
    ]
  }
}
