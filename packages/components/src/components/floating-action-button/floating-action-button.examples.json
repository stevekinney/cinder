{
  "$schema": "../../schemas/examples.schema.json",
  "component": "floating-action-button",
  "import": "@lostgradient/cinder/floating-action-button",
  "examples": [
    {
      "id": "basic",
      "title": "Floating Action Button",
      "description": "A circular primary-action button. Always provide aria-label for icon-only (filled) usage. Wrap in a fixed/sticky container to position it on the page.",
      "code": "<script lang=\"ts\">\n  import { FloatingActionButton } from '@lostgradient/cinder/floating-action-button';\n</script>\n\n<div style=\"display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap;\">\n  <!-- Primary filled FAB (default) -->\n  <FloatingActionButton aria-label=\"Add item\">\n    <svg\n      xmlns=\"http://www.w3.org/2000/svg\"\n      width=\"24\"\n      height=\"24\"\n      viewBox=\"0 0 24 24\"\n      fill=\"none\"\n      stroke=\"currentColor\"\n      stroke-width=\"2\"\n      stroke-linecap=\"round\"\n      stroke-linejoin=\"round\"\n      aria-hidden=\"true\"\n    >\n      <line x1=\"12\" y1=\"5\" x2=\"12\" y2=\"19\" />\n      <line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\" />\n    </svg>\n  </FloatingActionButton>\n\n  <!-- Secondary color -->\n  <FloatingActionButton color=\"secondary\" aria-label=\"Edit\">\n    <svg\n      xmlns=\"http://www.w3.org/2000/svg\"\n      width=\"24\"\n      height=\"24\"\n      viewBox=\"0 0 24 24\"\n      fill=\"none\"\n      stroke=\"currentColor\"\n      stroke-width=\"2\"\n      stroke-linecap=\"round\"\n      stroke-linejoin=\"round\"\n      aria-hidden=\"true\"\n    >\n      <path d=\"M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7\" />\n      <path d=\"M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z\" />\n    </svg>\n  </FloatingActionButton>\n\n  <!-- Surface color -->\n  <FloatingActionButton color=\"surface\" aria-label=\"Share\">\n    <svg\n      xmlns=\"http://www.w3.org/2000/svg\"\n      width=\"24\"\n      height=\"24\"\n      viewBox=\"0 0 24 24\"\n      fill=\"none\"\n      stroke=\"currentColor\"\n      stroke-width=\"2\"\n      stroke-linecap=\"round\"\n      stroke-linejoin=\"round\"\n      aria-hidden=\"true\"\n    >\n      <circle cx=\"18\" cy=\"5\" r=\"3\" />\n      <circle cx=\"6\" cy=\"12\" r=\"3\" />\n      <circle cx=\"18\" cy=\"19\" r=\"3\" />\n      <line x1=\"8.59\" y1=\"13.51\" x2=\"15.42\" y2=\"17.49\" />\n      <line x1=\"15.41\" y1=\"6.51\" x2=\"8.59\" y2=\"10.49\" />\n    </svg>\n  </FloatingActionButton>\n\n  <!-- Extended variant with icon + label -->\n  <FloatingActionButton variant=\"extended\" aria-label=\"Compose new message\">\n    <svg\n      xmlns=\"http://www.w3.org/2000/svg\"\n      width=\"20\"\n      height=\"20\"\n      viewBox=\"0 0 24 24\"\n      fill=\"none\"\n      stroke=\"currentColor\"\n      stroke-width=\"2\"\n      stroke-linecap=\"round\"\n      stroke-linejoin=\"round\"\n      aria-hidden=\"true\"\n    >\n      <line x1=\"12\" y1=\"5\" x2=\"12\" y2=\"19\" />\n      <line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\" />\n    </svg>\n    Compose\n  </FloatingActionButton>\n\n  <!-- Small size -->\n  <FloatingActionButton size=\"sm\" aria-label=\"Add small\">\n    <svg\n      xmlns=\"http://www.w3.org/2000/svg\"\n      width=\"16\"\n      height=\"16\"\n      viewBox=\"0 0 24 24\"\n      fill=\"none\"\n      stroke=\"currentColor\"\n      stroke-width=\"2\"\n      stroke-linecap=\"round\"\n      stroke-linejoin=\"round\"\n      aria-hidden=\"true\"\n    >\n      <line x1=\"12\" y1=\"5\" x2=\"12\" y2=\"19\" />\n      <line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\" />\n    </svg>\n  </FloatingActionButton>\n\n  <!-- Large size -->\n  <FloatingActionButton size=\"lg\" aria-label=\"Add large\">\n    <svg\n      xmlns=\"http://www.w3.org/2000/svg\"\n      width=\"32\"\n      height=\"32\"\n      viewBox=\"0 0 24 24\"\n      fill=\"none\"\n      stroke=\"currentColor\"\n      stroke-width=\"2\"\n      stroke-linecap=\"round\"\n      stroke-linejoin=\"round\"\n      aria-hidden=\"true\"\n    >\n      <line x1=\"12\" y1=\"5\" x2=\"12\" y2=\"19\" />\n      <line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\" />\n    </svg>\n  </FloatingActionButton>\n\n  <!-- Link FAB -->\n  <FloatingActionButton href=\"/new\" aria-label=\"Create new item\">\n    <svg\n      xmlns=\"http://www.w3.org/2000/svg\"\n      width=\"24\"\n      height=\"24\"\n      viewBox=\"0 0 24 24\"\n      fill=\"none\"\n      stroke=\"currentColor\"\n      stroke-width=\"2\"\n      stroke-linecap=\"round\"\n      stroke-linejoin=\"round\"\n      aria-hidden=\"true\"\n    >\n      <line x1=\"12\" y1=\"5\" x2=\"12\" y2=\"19\" />\n      <line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\" />\n    </svg>\n  </FloatingActionButton>\n\n  <!-- Disabled FAB -->\n  <FloatingActionButton disabled aria-label=\"Add (unavailable)\">\n    <svg\n      xmlns=\"http://www.w3.org/2000/svg\"\n      width=\"24\"\n      height=\"24\"\n      viewBox=\"0 0 24 24\"\n      fill=\"none\"\n      stroke=\"currentColor\"\n      stroke-width=\"2\"\n      stroke-linecap=\"round\"\n      stroke-linejoin=\"round\"\n      aria-hidden=\"true\"\n    >\n      <line x1=\"12\" y1=\"5\" x2=\"12\" y2=\"19\" />\n      <line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\" />\n    </svg>\n  </FloatingActionButton>\n</div>\n"
    }
  ]
}
