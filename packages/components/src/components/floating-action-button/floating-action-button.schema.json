{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "shape": {
      "enum": ["filled", "extended"],
      "description": "Shape. `filled` = circle, `extended` = pill.",
      "default": "filled"
    },
    "size": {
      "enum": ["sm", "md", "lg"],
      "description": "Size of the FAB.",
      "default": "md"
    },
    "variant": {
      "enum": ["primary", "secondary", "surface"],
      "description": "Color palette.",
      "default": "primary"
    },
    "disabled": {
      "type": "boolean",
      "description": "When true, disables the button and prevents interaction.",
      "default": false
    },
    "href": {
      "type": "string",
      "description": "Render as an anchor `<a>` element with this href."
    },
    "class": {
      "type": "string",
      "description": "Custom class merged with `.cinder-fab`."
    }
  },
  "additionalProperties": false,
  "metadata": {
    "unsupportedProps": [
      {
        "name": "children",
        "reason": "function-or-snippet",
        "description": "The icon (or icon + label for extended shape). Always provide `aria-label` when\nthe FAB renders an icon without visible text — i.e. the `filled` shape."
      }
    ]
  }
}
