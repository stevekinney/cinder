{
  "$schema": "../../schemas/examples.schema.json",
  "component": "spacer",
  "import": "cinder/spacer",
  "examples": [
    {
      "id": "basic",
      "title": "Spacer basic",
      "description": "Spacer pushes the trailing action to the far end of an Inline row.",
      "code": "<script lang=\"ts\">\n  import { Inline } from 'cinder/inline';\n  import { Spacer } from 'cinder/spacer';\n</script>\n\n<Inline>\n  <span>Leading label</span>\n  <Spacer />\n  <button type=\"button\">Trailing</button>\n</Inline>\n"
    }
  ]
}
