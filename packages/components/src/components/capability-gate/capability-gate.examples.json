{
  "$schema": "../../schemas/examples.schema.json",
  "component": "capability-gate",
  "import": "@lostgradient/cinder/capability-gate",
  "examples": [
    {
      "id": "microphone",
      "title": "Microphone permission gate",
      "description": "Shows the capability gate in each state for a microphone permission request.",
      "code": "<script lang=\"ts\">\n  import { Button } from '@lostgradient/cinder/button';\n  import { CapabilityGate } from '@lostgradient/cinder/capability-gate';\n  import type { CapabilityGateState } from '@lostgradient/cinder/capability-gate';\n\n  let capabilityState = $state<CapabilityGateState>('permission-needed');\n  const needsAction = $derived(capabilityState === 'permission-needed');\n\n  const states: CapabilityGateState[] = [\n    'supported',\n    'unsupported',\n    'permission-needed',\n    'permission-denied',\n    'loading',\n    'unavailable',\n  ];\n</script>\n\n<div style=\"display: flex; flex-direction: column; gap: 1rem; max-width: 28rem;\">\n  {#if needsAction}\n    <CapabilityGate\n      feature=\"Microphone\"\n      state={capabilityState}\n      primaryAction=\"Allow microphone\"\n      onPrimaryAction={() => {\n        capabilityState = 'supported';\n      }}\n      fallbackAction=\"Use text instead\"\n      onFallbackAction={() => {\n        capabilityState = 'unsupported';\n      }}\n    >\n      <p style=\"font-size: 0.875rem; color: var(--cinder-text-muted); margin: 0;\">\n        Microphone access is needed for voice input. Your audio is never stored or shared.\n      </p>\n    </CapabilityGate>\n  {:else}\n    <CapabilityGate feature=\"Microphone\" state={capabilityState} />\n  {/if}\n\n  <div style=\"display: flex; gap: 0.5rem; flex-wrap: wrap;\">\n    {#each states as s (s)}\n      <Button\n        size=\"sm\"\n        variant={capabilityState === s ? 'secondary' : 'ghost'}\n        onclick={() => {\n          capabilityState = s;\n        }}\n      >\n        {s}\n      </Button>\n    {/each}\n  </div>\n</div>\n"
    },
    {
      "id": "notifications",
      "title": "Notifications permission gate (banner)",
      "description": "A banner-style capability gate for browser notifications.",
      "code": "<script lang=\"ts\">\n  import { CapabilityGate } from '@lostgradient/cinder/capability-gate';\n</script>\n\n<div style=\"display: flex; flex-direction: column; gap: 1rem;\">\n  <CapabilityGate\n    feature=\"Notifications\"\n    state=\"permission-denied\"\n    variant=\"banner\"\n    fallbackAction=\"Enable in settings\"\n    fallbackHref=\"#\"\n    dismissAction=\"Dismiss\"\n  />\n  <CapabilityGate feature=\"Offline storage\" state=\"unsupported\" variant=\"callout\">\n    <p style=\"font-size: 0.875rem; color: var(--cinder-text-muted); margin: 0;\">\n      Your browser does not support offline storage. Some features may be limited.\n    </p>\n  </CapabilityGate>\n</div>\n"
    }
  ]
}
