{
  "$schema": "../../schemas/examples.schema.json",
  "component": "navigation-bar",
  "import": "cinder/navigation-bar",
  "examples": [
    {
      "id": "basic",
      "title": "Basic navigation bar",
      "description": "Brand, link and button navigation items, disabled state, and an action in the trailing slot.",
      "code": "<script lang=\"ts\">\n  import { Button } from 'cinder/button';\n  import { NavigationBar } from 'cinder/navigation-bar';\n  import { NavigationItem } from 'cinder/navigation-item';\n  let active = $state('home');\n  let mobileMenuOpen = $state(false);\n</script>\n\n<NavigationBar bind:mobileMenuOpen>\n  {#snippet brand()}\n    <strong>Acme</strong>\n  {/snippet}\n  {#snippet menuToggle(attrs)}\n    <button type=\"button\" {...attrs} aria-label={mobileMenuOpen ? 'Close menu' : 'Open menu'}>\n      ☰\n    </button>\n  {/snippet}\n  {#snippet items({ variant })}\n    <NavigationItem {variant} onclick={() => (active = 'home')} active={active === 'home'}>\n      Home\n    </NavigationItem>\n    <NavigationItem {variant} onclick={() => (active = 'docs')} active={active === 'docs'}>\n      Docs\n    </NavigationItem>\n    <NavigationItem {variant} href=\"#blog\" active={active === 'blog'}>Blog</NavigationItem>\n    <NavigationItem {variant} onclick={() => (active = 'billing')} disabled>Billing</NavigationItem>\n  {/snippet}\n  {#snippet actions()}\n    <Button variant=\"primary\" size=\"sm\" label=\"Sign up\" />\n  {/snippet}\n</NavigationBar>\n"
    }
  ]
}
