{
  "$schema": "../../schemas/examples.schema.json",
  "component": "navigation-bar",
  "import": "@lostgradient/cinder/navigation-bar",
  "examples": [
    {
      "id": "basic",
      "title": "Basic navigation bar",
      "description": "Brand, link and button navigation items, disabled state, and an action in the trailing slot.",
      "code": "<script lang=\"ts\">\n  import { Button } from '@lostgradient/cinder/button';\n  import { NavigationBar } from '@lostgradient/cinder/navigation-bar';\n  import { NavigationItem } from '@lostgradient/cinder/navigation-item';\n  let active = $state('home');\n  let mobileMenuOpen = $state(false);\n</script>\n\n<NavigationBar bind:mobileMenuOpen menuTogglePlacement=\"before-brand\">\n  {#snippet brand()}\n    <strong>Acme</strong>\n  {/snippet}\n  {#snippet menuToggle(attrs)}\n    <button type=\"button\" {...attrs} aria-label={mobileMenuOpen ? 'Close menu' : 'Open menu'}>\n      <span aria-hidden=\"true\">☰</span>\n    </button>\n  {/snippet}\n  {#snippet items({ variant })}\n    <NavigationItem {variant} onclick={() => (active = 'home')} active={active === 'home'}>\n      Home\n    </NavigationItem>\n    <NavigationItem {variant} onclick={() => (active = 'docs')} active={active === 'docs'}>\n      Docs\n    </NavigationItem>\n    <NavigationItem {variant} href=\"#blog\" active={active === 'blog'}>Blog</NavigationItem>\n    <NavigationItem {variant} onclick={() => (active = 'billing')} disabled>Billing</NavigationItem>\n  {/snippet}\n  {#snippet actions()}\n    <Button variant=\"primary\" size=\"sm\" label=\"Sign up\" />\n  {/snippet}\n</NavigationBar>\n"
    },
    {
      "id": "bottom-tabs",
      "title": "Bottom mobile tabs",
      "description": "NavigationBar can render a bottom tab-bar composition while links keep aria-current semantics.",
      "code": "<script lang=\"ts\">\n  import { NavigationBar } from '@lostgradient/cinder/navigation-bar';\n  import { NavigationItem } from '@lostgradient/cinder/navigation-item';\n\n  let active = $state('home');\n</script>\n\n<div style=\"max-width: 28rem; border: 1px solid var(--cinder-border-muted);\">\n  <main style=\"min-height: 10rem; padding: var(--cinder-space-4);\">\n    <strong>{active}</strong>\n  </main>\n  <NavigationBar placement=\"bottom\" showLabels=\"active\" label=\"Mobile primary navigation\">\n    {#snippet items({ variant })}\n      <NavigationItem {variant} onclick={() => (active = 'home')} active={active === 'home'}>\n        <span aria-hidden=\"true\">H</span>\n        <span data-cinder-navigation-label>Home</span>\n      </NavigationItem>\n      <NavigationItem {variant} onclick={() => (active = 'search')} active={active === 'search'}>\n        <span aria-hidden=\"true\">S</span>\n        <span data-cinder-navigation-label>Search</span>\n      </NavigationItem>\n      <NavigationItem\n        {variant}\n        onclick={() => (active = 'settings')}\n        active={active === 'settings'}\n      >\n        <span aria-hidden=\"true\">G</span>\n        <span data-cinder-navigation-label>Settings</span>\n      </NavigationItem>\n    {/snippet}\n  </NavigationBar>\n</div>\n"
    }
  ]
}
