{
  "$schema": "../../schemas/examples.schema.json",
  "component": "card",
  "import": "cinder/card",
  "examples": [
    {
      "id": "basic",
      "title": "Basic card",
      "description": "A plain bordered card with a single body region.",
      "code": "<script lang=\"ts\">\n  import { Card } from 'cinder/card';\n</script>\n\n<Card>\n  <div\n    style=\"min-block-size: 8rem; border: 1px dashed var(--cinder-border-muted); border-radius: var(--cinder-radius-sm); background: repeating-linear-gradient(-45deg, transparent, transparent 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5625rem);\"\n  ></div>\n</Card>\n"
    },
    {
      "id": "edge-to-edge-mobile",
      "title": "Card, edge-to-edge on mobile",
      "description": "A card that bleeds to the viewport edge below the mobile breakpoint.",
      "code": "<script lang=\"ts\">\n  import { Card } from 'cinder/card';\n</script>\n\n<Card edgeToEdgeOnMobile>\n  <div\n    style=\"min-block-size: 8rem; border: 1px dashed var(--cinder-border-muted); border-radius: var(--cinder-radius-sm); background: repeating-linear-gradient(-45deg, transparent, transparent 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5625rem);\"\n  ></div>\n</Card>\n"
    },
    {
      "id": "well-edge-to-edge-mobile",
      "title": "Well, edge-to-edge on mobile",
      "description": "A well that bleeds to the viewport edge below the mobile breakpoint.",
      "code": "<script lang=\"ts\">\n  import { Card } from 'cinder/card';\n</script>\n\n<Card variant=\"well\" edgeToEdgeOnMobile>\n  <div\n    style=\"min-block-size: 8rem; border: 1px dashed var(--cinder-border-muted); border-radius: var(--cinder-radius-sm); background: repeating-linear-gradient(-45deg, transparent, transparent 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5625rem);\"\n  ></div>\n</Card>\n"
    },
    {
      "id": "well-on-gray",
      "title": "Well on grey",
      "description": "A well presented on a muted surrounding surface.",
      "code": "<script lang=\"ts\">\n  import { Card } from 'cinder/card';\n</script>\n\n<div\n  style=\"padding: var(--cinder-space-4); border-radius: var(--cinder-radius-lg); background: var(--cinder-surface-inset);\"\n>\n  <Card variant=\"well\">\n    <div\n      style=\"min-block-size: 8rem; border: 1px dashed var(--cinder-border-muted); border-radius: var(--cinder-radius-sm); background: repeating-linear-gradient(-45deg, transparent, transparent 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5625rem);\"\n    ></div>\n  </Card>\n</div>\n"
    },
    {
      "id": "well",
      "title": "Well",
      "description": "A flatter inset container for low-emphasis grouped content.",
      "code": "<script lang=\"ts\">\n  import { Card } from 'cinder/card';\n</script>\n\n<Card variant=\"well\">\n  <div\n    style=\"min-block-size: 8rem; border: 1px dashed var(--cinder-border-muted); border-radius: var(--cinder-radius-sm); background: repeating-linear-gradient(-45deg, transparent, transparent 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5625rem);\"\n  ></div>\n</Card>\n"
    },
    {
      "id": "with-footer",
      "title": "Card with footer",
      "description": "A card with a separated footer region below the body.",
      "code": "<script lang=\"ts\">\n  import { Card } from 'cinder/card';\n</script>\n\n<Card>\n  <div\n    style=\"inline-size: 100%; min-block-size: 7rem; border: 1px dashed var(--cinder-border-muted); border-radius: var(--cinder-radius-sm); background: repeating-linear-gradient(-45deg, transparent, transparent 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5625rem);\"\n  ></div>\n  {#snippet footer()}\n    <div\n      style=\"inline-size: 100%; min-block-size: 1.5rem; border: 1px dashed var(--cinder-border-muted); border-radius: var(--cinder-radius-sm); background: repeating-linear-gradient(-45deg, transparent, transparent 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5625rem);\"\n    ></div>\n  {/snippet}\n</Card>\n"
    },
    {
      "id": "with-gray-body",
      "title": "Card with grey body",
      "description": "A card whose body uses the muted surface tone.",
      "code": "<script lang=\"ts\">\n  import { Card } from 'cinder/card';\n</script>\n\n<Card bodyTone=\"muted\">\n  {#snippet header()}\n    <div\n      style=\"inline-size: 100%; min-block-size: 1.5rem; border: 1px dashed var(--cinder-border-muted); border-radius: var(--cinder-radius-sm); background: repeating-linear-gradient(-45deg, transparent, transparent 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5625rem);\"\n    ></div>\n  {/snippet}\n  <div\n    style=\"inline-size: 100%; min-block-size: 7rem; border: 1px dashed var(--cinder-border-muted); border-radius: var(--cinder-radius-sm); background: repeating-linear-gradient(-45deg, transparent, transparent 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5625rem);\"\n  ></div>\n</Card>\n"
    },
    {
      "id": "with-gray-footer",
      "title": "Card with grey footer",
      "description": "A card whose footer uses the muted surface tone.",
      "code": "<script lang=\"ts\">\n  import { Card } from 'cinder/card';\n</script>\n\n<Card footerTone=\"muted\">\n  <div\n    style=\"inline-size: 100%; min-block-size: 7rem; border: 1px dashed var(--cinder-border-muted); border-radius: var(--cinder-radius-sm); background: repeating-linear-gradient(-45deg, transparent, transparent 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5625rem);\"\n  ></div>\n  {#snippet footer()}\n    <div\n      style=\"inline-size: 100%; min-block-size: 1.5rem; border: 1px dashed var(--cinder-border-muted); border-radius: var(--cinder-radius-sm); background: repeating-linear-gradient(-45deg, transparent, transparent 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5625rem);\"\n    ></div>\n  {/snippet}\n</Card>\n"
    },
    {
      "id": "with-header-and-footer",
      "title": "Card with header and footer",
      "description": "A card with separated header, body, and footer regions.",
      "code": "<script lang=\"ts\">\n  import { Card } from 'cinder/card';\n</script>\n\n<Card>\n  {#snippet header()}\n    <div\n      style=\"inline-size: 100%; min-block-size: 1.5rem; border: 1px dashed var(--cinder-border-muted); border-radius: var(--cinder-radius-sm); background: repeating-linear-gradient(-45deg, transparent, transparent 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5625rem);\"\n    ></div>\n  {/snippet}\n  <div\n    style=\"inline-size: 100%; min-block-size: 7rem; border: 1px dashed var(--cinder-border-muted); border-radius: var(--cinder-radius-sm); background: repeating-linear-gradient(-45deg, transparent, transparent 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5625rem);\"\n  ></div>\n  {#snippet footer()}\n    <div\n      style=\"inline-size: 100%; min-block-size: 1.5rem; border: 1px dashed var(--cinder-border-muted); border-radius: var(--cinder-radius-sm); background: repeating-linear-gradient(-45deg, transparent, transparent 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5625rem);\"\n    ></div>\n  {/snippet}\n</Card>\n"
    },
    {
      "id": "with-header",
      "title": "Card with header",
      "description": "A card with a separated header region above the body.",
      "code": "<script lang=\"ts\">\n  import { Card } from 'cinder/card';\n</script>\n\n<Card>\n  {#snippet header()}\n    <div\n      style=\"min-block-size: 1.5rem; border: 1px dashed var(--cinder-border-muted); border-radius: var(--cinder-radius-sm); background: repeating-linear-gradient(-45deg, transparent, transparent 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5625rem);\"\n    ></div>\n  {/snippet}\n  <div\n    style=\"min-block-size: 7rem; border: 1px dashed var(--cinder-border-muted); border-radius: var(--cinder-radius-sm); background: repeating-linear-gradient(-45deg, transparent, transparent 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5625rem);\"\n  ></div>\n</Card>\n"
    }
  ]
}
