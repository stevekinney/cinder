{
  "$schema": "../../schemas/examples.schema.json",
  "component": "card",
  "import": "@lostgradient/cinder/card",
  "examples": [
    {
      "id": "basic",
      "title": "Basic card",
      "description": "A plain bordered card with a single body region.",
      "code": "<script lang=\"ts\">\n  import { Card } from '@lostgradient/cinder/card';\n</script>\n\n<Card>\n  <div\n    style=\"min-block-size: 8rem; border: 1px dashed var(--cinder-border-muted); border-radius: var(--cinder-radius-sm); background: repeating-linear-gradient(-45deg, transparent, transparent 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5625rem);\"\n  ></div>\n</Card>\n"
    },
    {
      "id": "danger-zone-action",
      "title": "Danger zone action",
      "description": "A destructive action inside a danger-tone Card with the confirmation flow delegated to ConfirmDialog.",
      "code": "<script lang=\"ts\">\n  import { Button } from '@lostgradient/cinder/button';\n  import { Card } from '@lostgradient/cinder/card';\n  import { ConfirmDialog } from '@lostgradient/cinder/confirm-dialog';\n\n  let open = $state(false);\n  let triggerRef: HTMLElement | null = $state(null);\n  let deleted = $state(false);\n</script>\n\n<Card\n  tone=\"danger\"\n  title=\"Delete project\"\n  description=\"Permanently removes project settings, review history, and saved automation rules.\"\n>\n  <p style=\"margin: 0; color: var(--cinder-text-subtle); font-size: var(--cinder-text-sm);\">\n    {deleted\n      ? 'The deletion flow completed.'\n      : 'Export any data you need before deleting this project.'}\n  </p>\n\n  {#snippet footer()}\n    <Button\n      variant=\"danger\"\n      label=\"Delete project\"\n      disabled={deleted}\n      onclick={(event) => {\n        triggerRef = event.currentTarget as HTMLElement;\n        open = true;\n      }}\n    />\n  {/snippet}\n</Card>\n\n<ConfirmDialog\n  bind:open\n  {triggerRef}\n  title=\"Delete this project?\"\n  description=\"This action is permanent. Project settings, review history, and automation rules cannot be restored.\"\n  destructive\n  confirmLabel=\"Delete project\"\n  onconfirm={() => (deleted = true)}\n  oncancel={() => (open = false)}\n/>\n"
    },
    {
      "id": "danger-zone-toggle",
      "title": "Danger zone setting",
      "description": "A high-risk settings card with container-level danger treatment, a switch, and a confirmation dialog before the risky state is applied.",
      "code": "<script lang=\"ts\">\n  import { Button } from '@lostgradient/cinder/button';\n  import { Card } from '@lostgradient/cinder/card';\n  import { ConfirmDialog } from '@lostgradient/cinder/confirm-dialog';\n  import { Toggle } from '@lostgradient/cinder/toggle';\n\n  let paused = $state(false);\n  let confirmOpen = $state(false);\n\n  function requestPause(next: boolean): boolean {\n    if (!next) return false;\n    confirmOpen = true;\n    return paused;\n  }\n</script>\n\n<Card\n  tone=\"danger\"\n  title=\"Pause reviews\"\n  description=\"Stops new review dispatch globally. Existing in-flight reviews can finish, but no new work will be assigned until reviews are resumed.\"\n>\n  <div style=\"display: grid; gap: var(--cinder-space-3);\">\n    <Toggle\n      id=\"pause-reviews\"\n      bind:checked={paused}\n      label=\"Reviews paused\"\n      onValueChange={requestPause}\n    />\n    <p style=\"margin: 0; color: var(--cinder-text-subtle); font-size: var(--cinder-text-sm);\">\n      Current state: <strong>{paused ? 'Paused' : 'Dispatching reviews'}</strong>\n    </p>\n  </div>\n\n  {#snippet footer()}\n    {#if paused}\n      <Button variant=\"secondary\" label=\"Resume reviews\" onclick={() => (paused = false)} />\n    {/if}\n  {/snippet}\n</Card>\n\n<ConfirmDialog\n  bind:open={confirmOpen}\n  title=\"Pause review dispatch?\"\n  description=\"This affects every repository connected to the workspace. New reviews will stop until an administrator resumes dispatch.\"\n  destructive\n  confirmLabel=\"Pause reviews\"\n  onconfirm={() => (paused = true)}\n  oncancel={() => (confirmOpen = false)}\n/>\n"
    },
    {
      "id": "edge-to-edge-mobile",
      "title": "Card, edge-to-edge on mobile",
      "description": "A card that bleeds to the viewport edge below the mobile breakpoint.",
      "code": "<script lang=\"ts\">\n  import { Card } from '@lostgradient/cinder/card';\n</script>\n\n<Card edgeToEdgeOnMobile>\n  <div\n    style=\"min-block-size: 8rem; border: 1px dashed var(--cinder-border-muted); border-radius: var(--cinder-radius-sm); background: repeating-linear-gradient(-45deg, transparent, transparent 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5625rem);\"\n  ></div>\n</Card>\n"
    },
    {
      "id": "flush-body",
      "title": "Flush body (padding=\"none\")",
      "description": "Pass padding=\"none\" to remove the body padding for full-bleed content such as an image or a data table.",
      "code": "<script lang=\"ts\">\n  import { Card } from '@lostgradient/cinder/card';\n</script>\n\n<Card title=\"Full-bleed image card\" padding=\"none\">\n  <div\n    style=\"min-block-size: 8rem; background: var(--cinder-surface-inset); border-top: 1px solid var(--cinder-border-muted); display: flex; align-items: center; justify-content: center; color: var(--cinder-text-subtle); font-size: var(--cinder-text-sm);\"\n  >\n    full-bleed content area\n  </div>\n</Card>\n"
    },
    {
      "id": "well-edge-to-edge-mobile",
      "title": "Well, edge-to-edge on mobile",
      "description": "A well that bleeds to the viewport edge below the mobile breakpoint.",
      "code": "<script lang=\"ts\">\n  import { Card } from '@lostgradient/cinder/card';\n</script>\n\n<Card variant=\"well\" edgeToEdgeOnMobile>\n  <div\n    style=\"min-block-size: 8rem; border: 1px dashed var(--cinder-border-muted); border-radius: var(--cinder-radius-sm); background: repeating-linear-gradient(-45deg, transparent, transparent 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5625rem);\"\n  ></div>\n</Card>\n"
    },
    {
      "id": "well-on-gray",
      "title": "Well on grey",
      "description": "A well presented on a muted surrounding surface.",
      "code": "<script lang=\"ts\">\n  import { Card } from '@lostgradient/cinder/card';\n</script>\n\n<div\n  style=\"padding: var(--cinder-space-4); border-radius: var(--cinder-radius-lg); background: var(--cinder-surface-inset);\"\n>\n  <Card variant=\"well\">\n    <div\n      style=\"min-block-size: 8rem; border: 1px dashed var(--cinder-border-muted); border-radius: var(--cinder-radius-sm); background: repeating-linear-gradient(-45deg, transparent, transparent 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5625rem);\"\n    ></div>\n  </Card>\n</div>\n"
    },
    {
      "id": "well",
      "title": "Well",
      "description": "A flatter inset container for low-emphasis grouped content.",
      "code": "<script lang=\"ts\">\n  import { Card } from '@lostgradient/cinder/card';\n</script>\n\n<Card variant=\"well\">\n  <div\n    style=\"min-block-size: 8rem; border: 1px dashed var(--cinder-border-muted); border-radius: var(--cinder-radius-sm); background: repeating-linear-gradient(-45deg, transparent, transparent 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5625rem);\"\n  ></div>\n</Card>\n"
    },
    {
      "id": "with-footer",
      "title": "Card with footer",
      "description": "A card with a separated footer region below the body.",
      "code": "<script lang=\"ts\">\n  import { Card } from '@lostgradient/cinder/card';\n</script>\n\n<Card>\n  <div\n    style=\"inline-size: 100%; min-block-size: 7rem; border: 1px dashed var(--cinder-border-muted); border-radius: var(--cinder-radius-sm); background: repeating-linear-gradient(-45deg, transparent, transparent 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5625rem);\"\n  ></div>\n  {#snippet footer()}\n    <div\n      style=\"inline-size: 100%; min-block-size: 1.5rem; border: 1px dashed var(--cinder-border-muted); border-radius: var(--cinder-radius-sm); background: repeating-linear-gradient(-45deg, transparent, transparent 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5625rem);\"\n    ></div>\n  {/snippet}\n</Card>\n"
    },
    {
      "id": "with-gray-body",
      "title": "Card with grey body",
      "description": "A card whose body uses the muted surface tone.",
      "code": "<script lang=\"ts\">\n  import { Card } from '@lostgradient/cinder/card';\n</script>\n\n<Card bodyTone=\"muted\">\n  {#snippet header()}\n    <div\n      style=\"inline-size: 100%; min-block-size: 1.5rem; border: 1px dashed var(--cinder-border-muted); border-radius: var(--cinder-radius-sm); background: repeating-linear-gradient(-45deg, transparent, transparent 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5625rem);\"\n    ></div>\n  {/snippet}\n  <div\n    style=\"inline-size: 100%; min-block-size: 7rem; border: 1px dashed var(--cinder-border-muted); border-radius: var(--cinder-radius-sm); background: repeating-linear-gradient(-45deg, transparent, transparent 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5625rem);\"\n  ></div>\n</Card>\n"
    },
    {
      "id": "with-gray-footer",
      "title": "Card with grey footer",
      "description": "A card whose footer uses the muted surface tone.",
      "code": "<script lang=\"ts\">\n  import { Card } from '@lostgradient/cinder/card';\n</script>\n\n<Card footerTone=\"muted\">\n  <div\n    style=\"inline-size: 100%; min-block-size: 7rem; border: 1px dashed var(--cinder-border-muted); border-radius: var(--cinder-radius-sm); background: repeating-linear-gradient(-45deg, transparent, transparent 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5625rem);\"\n  ></div>\n  {#snippet footer()}\n    <div\n      style=\"inline-size: 100%; min-block-size: 1.5rem; border: 1px dashed var(--cinder-border-muted); border-radius: var(--cinder-radius-sm); background: repeating-linear-gradient(-45deg, transparent, transparent 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5625rem);\"\n    ></div>\n  {/snippet}\n</Card>\n"
    },
    {
      "id": "with-header-and-footer",
      "title": "Card with header and footer",
      "description": "A card with separated header, body, and footer regions.",
      "code": "<script lang=\"ts\">\n  import { Card } from '@lostgradient/cinder/card';\n</script>\n\n<Card>\n  {#snippet header()}\n    <div\n      style=\"inline-size: 100%; min-block-size: 1.5rem; border: 1px dashed var(--cinder-border-muted); border-radius: var(--cinder-radius-sm); background: repeating-linear-gradient(-45deg, transparent, transparent 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5625rem);\"\n    ></div>\n  {/snippet}\n  <div\n    style=\"inline-size: 100%; min-block-size: 7rem; border: 1px dashed var(--cinder-border-muted); border-radius: var(--cinder-radius-sm); background: repeating-linear-gradient(-45deg, transparent, transparent 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5625rem);\"\n  ></div>\n  {#snippet footer()}\n    <div\n      style=\"inline-size: 100%; min-block-size: 1.5rem; border: 1px dashed var(--cinder-border-muted); border-radius: var(--cinder-radius-sm); background: repeating-linear-gradient(-45deg, transparent, transparent 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5625rem);\"\n    ></div>\n  {/snippet}\n</Card>\n"
    },
    {
      "id": "with-header",
      "title": "Card with header",
      "description": "A card with a separated header region above the body.",
      "code": "<script lang=\"ts\">\n  import { Card } from '@lostgradient/cinder/card';\n</script>\n\n<Card>\n  {#snippet header()}\n    <div\n      style=\"min-block-size: 1.5rem; border: 1px dashed var(--cinder-border-muted); border-radius: var(--cinder-radius-sm); background: repeating-linear-gradient(-45deg, transparent, transparent 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5625rem);\"\n    ></div>\n  {/snippet}\n  <div\n    style=\"min-block-size: 7rem; border: 1px dashed var(--cinder-border-muted); border-radius: var(--cinder-radius-sm); background: repeating-linear-gradient(-45deg, transparent, transparent 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5rem, color-mix(in oklch, var(--cinder-border-muted), transparent 70%) 0.5625rem);\"\n  ></div>\n</Card>\n"
    }
  ]
}
