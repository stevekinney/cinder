{
  "$schema": "../../schemas/examples.schema.json",
  "component": "button",
  "import": "cinder/button",
  "examples": [
    {
      "id": "as-link",
      "title": "Button as link",
      "description": "Passing href renders an anchor element with button styling.",
      "code": "<script lang=\"ts\">\n  import { Button } from 'cinder/button';\n</script>\n\n<div class=\"example-preview-row\">\n  <Button href=\"https://svelte.dev\" target=\"_blank\" rel=\"noopener noreferrer\" label=\"Svelte docs\" />\n  <Button href=\"#\" variant=\"ghost\" label=\"Internal link\" />\n</div>\n"
    },
    {
      "id": "icon-only",
      "title": "Icon-only buttons",
      "description": "Icon-only buttons keep the visual surface compact while still carrying an accessible name through label or aria-label.",
      "code": "<script lang=\"ts\">\n  import { Button } from 'cinder/button';\n</script>\n\n<div class=\"example-preview-row\">\n  <Button iconOnly={true} label=\"Close\" variant=\"ghost\" data-testid=\"button-ghost-icon-only-rest\">\n    {#snippet leadingIcon()}\n      <svg\n        xmlns=\"http://www.w3.org/2000/svg\"\n        width=\"16\"\n        height=\"16\"\n        viewBox=\"0 0 24 24\"\n        fill=\"none\"\n        stroke=\"currentColor\"\n        stroke-width=\"2\"\n        stroke-linecap=\"round\"\n        stroke-linejoin=\"round\"\n        aria-hidden=\"true\"\n      >\n        <line x1=\"18\" y1=\"6\" x2=\"6\" y2=\"18\" />\n        <line x1=\"6\" y1=\"6\" x2=\"18\" y2=\"18\" />\n      </svg>\n    {/snippet}\n  </Button>\n\n  <Button\n    iconOnly={true}\n    label=\"Delete\"\n    variant=\"ghost-danger\"\n    data-testid=\"button-ghost-danger-icon-only-rest\"\n  >\n    {#snippet leadingIcon()}\n      <svg\n        xmlns=\"http://www.w3.org/2000/svg\"\n        width=\"16\"\n        height=\"16\"\n        viewBox=\"0 0 24 24\"\n        fill=\"none\"\n        stroke=\"currentColor\"\n        stroke-width=\"2\"\n        stroke-linecap=\"round\"\n        stroke-linejoin=\"round\"\n        aria-hidden=\"true\"\n      >\n        <polyline points=\"3 6 5 6 21 6\" />\n        <path d=\"M19 6l-1 14H6L5 6\" />\n        <path d=\"M10 11v6\" />\n        <path d=\"M14 11v6\" />\n        <path d=\"M9 6V4h6v2\" />\n      </svg>\n    {/snippet}\n  </Button>\n\n  <Button iconOnly={true} label=\"Search\" variant=\"secondary\">\n    {#snippet leadingIcon()}\n      <svg\n        xmlns=\"http://www.w3.org/2000/svg\"\n        width=\"16\"\n        height=\"16\"\n        viewBox=\"0 0 24 24\"\n        fill=\"none\"\n        stroke=\"currentColor\"\n        stroke-width=\"2\"\n        stroke-linecap=\"round\"\n        stroke-linejoin=\"round\"\n        aria-hidden=\"true\"\n      >\n        <circle cx=\"11\" cy=\"11\" r=\"8\" />\n        <line x1=\"21\" y1=\"21\" x2=\"16.65\" y2=\"16.65\" />\n      </svg>\n    {/snippet}\n  </Button>\n</div>\n\n<div class=\"example-preview-row\">\n  <Button\n    disabled={true}\n    iconOnly={true}\n    label=\"Disabled close\"\n    variant=\"ghost\"\n    data-testid=\"button-ghost-icon-only-disabled\"\n  >\n    {#snippet leadingIcon()}\n      <svg\n        xmlns=\"http://www.w3.org/2000/svg\"\n        width=\"16\"\n        height=\"16\"\n        viewBox=\"0 0 24 24\"\n        fill=\"none\"\n        stroke=\"currentColor\"\n        stroke-width=\"2\"\n        stroke-linecap=\"round\"\n        stroke-linejoin=\"round\"\n        aria-hidden=\"true\"\n      >\n        <line x1=\"18\" y1=\"6\" x2=\"6\" y2=\"18\" />\n        <line x1=\"6\" y1=\"6\" x2=\"18\" y2=\"18\" />\n      </svg>\n    {/snippet}\n  </Button>\n\n  <Button\n    disabled={true}\n    iconOnly={true}\n    label=\"Disabled delete\"\n    variant=\"ghost-danger\"\n    data-testid=\"button-ghost-danger-icon-only-disabled\"\n  >\n    {#snippet leadingIcon()}\n      <svg\n        xmlns=\"http://www.w3.org/2000/svg\"\n        width=\"16\"\n        height=\"16\"\n        viewBox=\"0 0 24 24\"\n        fill=\"none\"\n        stroke=\"currentColor\"\n        stroke-width=\"2\"\n        stroke-linecap=\"round\"\n        stroke-linejoin=\"round\"\n        aria-hidden=\"true\"\n      >\n        <polyline points=\"3 6 5 6 21 6\" />\n        <path d=\"M19 6l-1 14H6L5 6\" />\n        <path d=\"M10 11v6\" />\n        <path d=\"M14 11v6\" />\n        <path d=\"M9 6V4h6v2\" />\n      </svg>\n    {/snippet}\n  </Button>\n\n  <Button\n    href=\"#disabled-close\"\n    aria-disabled=\"true\"\n    iconOnly={true}\n    label=\"Unavailable close link\"\n    variant=\"ghost\"\n    data-testid=\"button-ghost-icon-only-aria-disabled-link\"\n  >\n    {#snippet leadingIcon()}\n      <svg\n        xmlns=\"http://www.w3.org/2000/svg\"\n        width=\"16\"\n        height=\"16\"\n        viewBox=\"0 0 24 24\"\n        fill=\"none\"\n        stroke=\"currentColor\"\n        stroke-width=\"2\"\n        stroke-linecap=\"round\"\n        stroke-linejoin=\"round\"\n        aria-hidden=\"true\"\n      >\n        <line x1=\"18\" y1=\"6\" x2=\"6\" y2=\"18\" />\n        <line x1=\"6\" y1=\"6\" x2=\"18\" y2=\"18\" />\n      </svg>\n    {/snippet}\n  </Button>\n\n  <Button\n    href=\"#disabled-delete\"\n    aria-disabled=\"true\"\n    iconOnly={true}\n    label=\"Unavailable delete link\"\n    variant=\"ghost-danger\"\n    data-testid=\"button-ghost-danger-icon-only-aria-disabled-link\"\n  >\n    {#snippet leadingIcon()}\n      <svg\n        xmlns=\"http://www.w3.org/2000/svg\"\n        width=\"16\"\n        height=\"16\"\n        viewBox=\"0 0 24 24\"\n        fill=\"none\"\n        stroke=\"currentColor\"\n        stroke-width=\"2\"\n        stroke-linecap=\"round\"\n        stroke-linejoin=\"round\"\n        aria-hidden=\"true\"\n      >\n        <polyline points=\"3 6 5 6 21 6\" />\n        <path d=\"M19 6l-1 14H6L5 6\" />\n        <path d=\"M10 11v6\" />\n        <path d=\"M14 11v6\" />\n        <path d=\"M9 6V4h6v2\" />\n      </svg>\n    {/snippet}\n  </Button>\n</div>\n"
    },
    {
      "id": "loading",
      "title": "Loading state",
      "description": "A permanent loading button alongside one that toggles loading on click; both render the spinner and set aria-busy.",
      "code": "<script lang=\"ts\">\n  import { Button } from 'cinder/button';\n  let loading = $state(false);\n\n  async function handleClick() {\n    loading = true;\n    await new Promise((resolve) => setTimeout(resolve, 2000));\n    loading = false;\n  }\n</script>\n\n<div class=\"example-preview-row\">\n  <Button variant=\"primary\" label=\"Saving...\" loading />\n  <Button variant=\"primary\" label=\"Save changes\" {loading} onclick={handleClick} />\n</div>\n"
    },
    {
      "id": "primary",
      "title": "Primary button",
      "description": "The default button variant.",
      "code": "<script lang=\"ts\">\n  import { Button } from 'cinder/button';\n</script>\n\n<Button label=\"Click me\" />\n"
    },
    {
      "id": "sizes",
      "title": "Button sizes",
      "description": "xs, sm, md, lg, and xl sizes.",
      "code": "<script lang=\"ts\">\n  import { Button } from 'cinder/button';\n</script>\n\n<div class=\"example-preview-row\">\n  <Button size=\"xs\" label=\"Extra Small\" />\n  <Button size=\"sm\" label=\"Small\" />\n  <Button size=\"md\" label=\"Medium\" />\n  <Button size=\"lg\" label=\"Large\" />\n  <Button size=\"xl\" label=\"Extra Large\" />\n</div>\n"
    },
    {
      "id": "soft",
      "title": "Soft variants",
      "description": "Soft and soft-danger use a tinted fill with no border — mid-emphasis between ghost and primary/danger.",
      "code": "<script lang=\"ts\">\n  import { Button } from 'cinder/button';\n</script>\n\n<div class=\"example-preview-row\">\n  <Button variant=\"soft\" label=\"Soft\" />\n  <Button variant=\"soft-danger\" label=\"Soft Danger\" />\n</div>\n"
    },
    {
      "id": "text-with-icons",
      "title": "Text + icon buttons",
      "description": "leadingIcon and trailingIcon snippets are decorative-only and wrap their SVGs in aria-hidden. Meaning still lives in the button label.",
      "code": "<script lang=\"ts\">\n  import { Button } from 'cinder/button';\n</script>\n\n<div class=\"example-preview-row\">\n  <Button variant=\"primary\" label=\"Save\">\n    {#snippet leadingIcon()}\n      <svg\n        xmlns=\"http://www.w3.org/2000/svg\"\n        width=\"14\"\n        height=\"14\"\n        viewBox=\"0 0 24 24\"\n        fill=\"none\"\n        stroke=\"currentColor\"\n        stroke-width=\"2\"\n        stroke-linecap=\"round\"\n        stroke-linejoin=\"round\"\n        aria-hidden=\"true\"\n      >\n        <path d=\"M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z\" />\n        <polyline points=\"17 21 17 13 7 13 7 21\" />\n        <polyline points=\"7 3 7 8 15 8\" />\n      </svg>\n    {/snippet}\n  </Button>\n\n  <Button variant=\"secondary\" label=\"Next\">\n    {#snippet trailingIcon()}\n      <svg\n        xmlns=\"http://www.w3.org/2000/svg\"\n        width=\"14\"\n        height=\"14\"\n        viewBox=\"0 0 24 24\"\n        fill=\"none\"\n        stroke=\"currentColor\"\n        stroke-width=\"2\"\n        stroke-linecap=\"round\"\n        stroke-linejoin=\"round\"\n        aria-hidden=\"true\"\n      >\n        <polyline points=\"9 18 15 12 9 6\" />\n      </svg>\n    {/snippet}\n  </Button>\n\n  <Button variant=\"ghost\" label=\"Share\" data-testid=\"button-ghost-text-share\">\n    {#snippet leadingIcon()}\n      <svg\n        xmlns=\"http://www.w3.org/2000/svg\"\n        width=\"14\"\n        height=\"14\"\n        viewBox=\"0 0 24 24\"\n        fill=\"none\"\n        stroke=\"currentColor\"\n        stroke-width=\"2\"\n        stroke-linecap=\"round\"\n        stroke-linejoin=\"round\"\n        aria-hidden=\"true\"\n      >\n        <circle cx=\"18\" cy=\"5\" r=\"3\" />\n        <circle cx=\"6\" cy=\"12\" r=\"3\" />\n        <circle cx=\"18\" cy=\"19\" r=\"3\" />\n        <line x1=\"8.59\" y1=\"13.51\" x2=\"15.42\" y2=\"17.49\" />\n        <line x1=\"15.41\" y1=\"6.51\" x2=\"8.59\" y2=\"10.49\" />\n      </svg>\n    {/snippet}\n  </Button>\n</div>\n"
    },
    {
      "id": "variants",
      "title": "Button variants",
      "description": "Primary, secondary, danger, and ghost styles.",
      "code": "<script lang=\"ts\">\n  import { Button } from 'cinder/button';\n</script>\n\n<div class=\"example-preview-row\">\n  <Button variant=\"primary\" label=\"Primary\" />\n  <Button variant=\"secondary\" label=\"Secondary\" />\n  <Button variant=\"danger\" label=\"Danger\" />\n  <Button variant=\"ghost\" label=\"Ghost\" />\n</div>\n"
    }
  ]
}
