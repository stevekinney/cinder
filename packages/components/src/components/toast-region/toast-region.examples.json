{
  "$schema": "../../schemas/examples.schema.json",
  "component": "toast-region",
  "import": "cinder/toast-region",
  "examples": [
    {
      "id": "action-button",
      "title": "Action button",
      "description": "Default action dismisses after firing; keepOpen: true keeps the toast visible after the action runs.",
      "code": "<script lang=\"ts\">\n  import { useToast } from 'cinder';\n  import { Button } from 'cinder/button';\n  import { ToastRegion } from 'cinder/toast-region';\n  let undoCount = $state(0);\n  let pauseCount = $state(0);\n</script>\n\n<ToastRegion>\n  {#snippet children()}\n    {@const toast = useToast()}\n    <div class=\"example-preview-row\">\n      <Button\n        label=\"Dismiss-after-action\"\n        onclick={() =>\n          toast.show('Item moved to trash.', {\n            variant: 'info',\n            duration: 0,\n            action: {\n              label: 'Undo',\n              onAction: () => (undoCount += 1),\n            },\n          })}\n      />\n      <Button\n        variant=\"secondary\"\n        label=\"Keep open after action\"\n        onclick={() =>\n          toast.show('Syncing in the background…', {\n            variant: 'info',\n            duration: 0,\n            action: {\n              label: 'Pause',\n              keepOpen: true,\n              onAction: () => (pauseCount += 1),\n            },\n          })}\n      />\n    </div>\n    <p style=\"margin-top: 0.75rem; font-size: 0.875rem;\">\n      Undo fired: {undoCount} · Pause fired: {pauseCount}\n    </p>\n  {/snippet}\n</ToastRegion>\n"
    },
    {
      "id": "basic",
      "title": "Basic toast region",
      "description": "Click the trigger to dispatch a transient toast into the live region.",
      "code": "<script lang=\"ts\">\n  import { useToast } from 'cinder';\n  import { Button } from 'cinder/button';\n  import { ToastRegion } from 'cinder/toast-region';\n</script>\n\n<ToastRegion>\n  {#snippet children()}\n    {@const toast = useToast()}\n    <div class=\"example-preview-row\">\n      <Button\n        label=\"Show success\"\n        onclick={() => toast.show('Saved your changes.', { variant: 'success' })}\n      />\n      <Button\n        variant=\"secondary\"\n        label=\"Show info\"\n        onclick={() => toast.show('A new version is available.', { variant: 'info' })}\n      />\n    </div>\n  {/snippet}\n</ToastRegion>\n"
    },
    {
      "id": "dismissible",
      "title": "Dismissible sticky toast",
      "description": "duration: 0 keeps the toast until the user dismisses it.",
      "code": "<script lang=\"ts\">\n  import { useToast } from 'cinder';\n  import { Button } from 'cinder/button';\n  import { ToastRegion } from 'cinder/toast-region';\n</script>\n\n<ToastRegion>\n  {#snippet children()}\n    {@const toast = useToast()}\n    <div class=\"example-preview-row\">\n      <Button\n        label=\"Show sticky warning\"\n        variant=\"secondary\"\n        onclick={() =>\n          toast.show('Your session expires in 5 minutes.', {\n            variant: 'warning',\n            duration: 0,\n            dismissible: true,\n          })}\n      />\n    </div>\n  {/snippet}\n</ToastRegion>\n"
    },
    {
      "id": "modal-scoped",
      "title": "Modal-scoped region",
      "description": "Nest <ToastRegion> inside a Modal to scope toasts to the modal content. When the modal body unmounts on close, the region tears down with it and pending timers are cleared.",
      "code": "<script lang=\"ts\">\n  import { useToast } from 'cinder';\n  import { Button } from 'cinder/button';\n  import { Modal } from 'cinder/modal';\n  import { ToastRegion } from 'cinder/toast-region';\n  let open = $state(false);\n  let triggerRef: HTMLElement | null = $state(null);\n</script>\n\n<Button\n  label=\"Open modal\"\n  onclick={(event) => {\n    triggerRef = event.currentTarget;\n    open = true;\n  }}\n/>\n\n<Modal bind:open title=\"Modal-scoped toasts\" {triggerRef}>\n  <ToastRegion>\n    {#snippet children()}\n      {@const toast = useToast()}\n      <p>\n        Toasts dispatched here belong to this modal's region. When the modal closes, its region\n        unmounts and any active toasts are torn down.\n      </p>\n      <div class=\"example-preview-row\">\n        <Button\n          label=\"Show success\"\n          onclick={() => toast.show('Saved inside the modal.', { variant: 'success' })}\n        />\n        <Button\n          variant=\"danger\"\n          label=\"Show danger\"\n          onclick={() => toast.show('Something went wrong.', { variant: 'danger' })}\n        />\n      </div>\n    {/snippet}\n  </ToastRegion>\n  {#snippet footer()}\n    <div style=\"display: flex; gap: 0.5rem; justify-content: flex-end;\">\n      <Button variant=\"secondary\" label=\"Close\" onclick={() => (open = false)} />\n    </div>\n  {/snippet}\n</Modal>\n"
    },
    {
      "id": "programmatic-dismiss",
      "title": "Programmatic dismiss",
      "description": "show() returns the toast id. Capture it to dismiss a specific toast, or call dismissAll() to clear both stacks.",
      "code": "<script lang=\"ts\">\n  import { useToast } from 'cinder';\n  import { Button } from 'cinder/button';\n  import { ToastRegion } from 'cinder/toast-region';\n  let lastId: string | null = $state(null);\n</script>\n\n<ToastRegion>\n  {#snippet children()}\n    {@const toast = useToast()}\n    <div class=\"example-preview-row\">\n      <Button\n        label=\"Show sticky\"\n        onclick={() => {\n          lastId = toast.show('Sticky toast — dismiss me programmatically.', {\n            variant: 'info',\n            duration: 0,\n          });\n        }}\n      />\n      <Button\n        variant=\"secondary\"\n        label=\"Dismiss last\"\n        onclick={() => {\n          if (lastId) {\n            toast.dismiss(lastId);\n            lastId = null;\n          }\n        }}\n      />\n      <Button variant=\"secondary\" label=\"Dismiss all\" onclick={() => toast.dismissAll()} />\n    </div>\n  {/snippet}\n</ToastRegion>\n"
    },
    {
      "id": "variants",
      "title": "All four variants",
      "description": "info and success route to the polite (status) region; warning and danger route to the assertive (alert) region.",
      "code": "<script lang=\"ts\">\n  import { useToast } from 'cinder';\n  import { Button } from 'cinder/button';\n  import { ToastRegion } from 'cinder/toast-region';\n</script>\n\n<ToastRegion>\n  {#snippet children()}\n    {@const toast = useToast()}\n    <div class=\"example-preview-row\">\n      <Button\n        label=\"Info\"\n        onclick={() => toast.show('A new version is available.', { variant: 'info' })}\n      />\n      <Button\n        label=\"Success\"\n        onclick={() => toast.show('Saved your changes.', { variant: 'success' })}\n      />\n      <Button\n        variant=\"secondary\"\n        label=\"Warning\"\n        onclick={() => toast.show('Your session expires in 5 minutes.', { variant: 'warning' })}\n      />\n      <Button\n        variant=\"danger\"\n        label=\"Danger\"\n        onclick={() => toast.show('Failed to save your changes.', { variant: 'danger' })}\n      />\n    </div>\n  {/snippet}\n</ToastRegion>\n"
    }
  ]
}
