{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "open": {
      "type": "boolean"
    },
    "title": {
      "type": "string"
    },
    "dismissOnBackdropClick": {
      "type": "boolean"
    },
    "dismissOnEscape": {
      "type": "boolean"
    },
    "showCloseButton": {
      "type": "boolean"
    },
    "class": {
      "type": "string"
    },
    "role": {
      "enum": ["dialog", "alertdialog"]
    },
    "describedById": {
      "type": "string",
      "description": "When set, applied as aria-describedby on the underlying <dialog>. Pass a short, plain description ID only."
    }
  },
  "additionalProperties": false,
  "required": ["open", "title"],
  "metadata": {
    "unsupportedProps": [
      {
        "name": "children",
        "reason": "function-or-snippet"
      },
      {
        "name": "footer",
        "reason": "function-or-snippet"
      },
      {
        "name": "ondismiss",
        "reason": "function-or-snippet"
      },
      {
        "name": "triggerRef",
        "reason": "unknown-shape"
      }
    ]
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "role": {
            "const": "alertdialog"
          }
        },
        "required": ["role"]
      },
      "then": {
        "required": ["describedById"]
      }
    }
  ]
}
