{
  "$schema": "../../schemas/examples.schema.json",
  "component": "modal",
  "import": "@lostgradient/cinder/modal",
  "examples": [
    {
      "id": "basic",
      "title": "Basic modal",
      "description": "A modal used as a generic content shell — in this case an invite form with structured fields.",
      "code": "<script lang=\"ts\">\n  import { Button } from '@lostgradient/cinder/button';\n  import { Input } from '@lostgradient/cinder/input';\n  import { Modal } from '@lostgradient/cinder/modal';\n\n  let open = $state(false);\n  let triggerRef: HTMLElement | null = $state(null);\n  let email = $state('');\n  let name = $state('');\n\n  function handleSend() {\n    open = false;\n  }\n</script>\n\n<Button\n  label=\"Invite teammate\"\n  onclick={(event) => {\n    triggerRef = event.currentTarget;\n    open = true;\n  }}\n/>\n\n<Modal bind:open title=\"Invite teammate\" {triggerRef}>\n  <div style=\"display: grid; gap: 1rem;\">\n    <Input id=\"invite-name\" label=\"Full name\" placeholder=\"Alex Kim\" bind:value={name} autofocus />\n    <Input\n      id=\"invite-email\"\n      label=\"Email address\"\n      type=\"email\"\n      placeholder=\"alex@example.com\"\n      bind:value={email}\n    />\n  </div>\n\n  {#snippet footer()}\n    <div style=\"display: flex; gap: 0.5rem; justify-content: flex-end;\">\n      <Button variant=\"secondary\" label=\"Cancel\" onclick={() => (open = false)} />\n      <Button variant=\"primary\" label=\"Send invite\" onclick={handleSend} />\n    </div>\n  {/snippet}\n</Modal>\n"
    },
    {
      "id": "overflowing",
      "title": "Overflowing modal",
      "description": "A modal body with enough content to scroll.",
      "code": "<script lang=\"ts\">\n  import { Button } from '@lostgradient/cinder/button';\n  import { Modal } from '@lostgradient/cinder/modal';\n\n  let open = $state(false);\n  let longContent = $state(true);\n  let triggerRef: HTMLElement | null = $state(null);\n\n  const sections = Array.from({ length: 12 }, (_, index) => ({\n    id: `section-${index + 1}`,\n    title: `Review section ${index + 1}`,\n    body: 'Operational notes, approval context, and supporting detail for the current workflow.',\n  }));\n</script>\n\n<div style=\"display: flex; flex-wrap: wrap; gap: 0.75rem; align-items: center;\">\n  <Button\n    label=\"Open modal\"\n    onclick={(event) => {\n      triggerRef = event.currentTarget as HTMLElement;\n      open = true;\n    }}\n  />\n  <Button\n    label={longContent ? 'Use short content' : 'Use long content'}\n    variant=\"secondary\"\n    onclick={() => (longContent = !longContent)}\n  />\n</div>\n\n<Modal bind:open title=\"Release checklist\" {triggerRef}>\n  {#if longContent}\n    <div style=\"display: grid; gap: 1rem;\">\n      {#each sections as section (section.id)}\n        <section>\n          <h3 style=\"margin: 0 0 0.25rem; font-size: var(--cinder-text-base);\">\n            {section.title}\n          </h3>\n          <p style=\"margin: 0; color: var(--cinder-text-muted);\">{section.body}</p>\n        </section>\n      {/each}\n    </div>\n  {:else}\n    <p style=\"margin: 0;\">This short body should fit without a scroll fade.</p>\n  {/if}\n\n  {#snippet footer()}\n    <Button label=\"Close\" onclick={() => (open = false)} />\n  {/snippet}\n</Modal>\n"
    },
    {
      "id": "with-form",
      "title": "Modal with form",
      "description": "A modal whose first input carries autofocus; the native dialog focuses it on open.",
      "code": "<script lang=\"ts\">\n  import { Button } from '@lostgradient/cinder/button';\n  import { Input } from '@lostgradient/cinder/input';\n  import { Modal } from '@lostgradient/cinder/modal';\n  let open = $state(false);\n  let name = $state('');\n  let triggerRef: HTMLElement | null = $state(null);\n</script>\n\n<Button\n  label=\"Rename item\"\n  onclick={(event) => {\n    triggerRef = event.currentTarget;\n    open = true;\n  }}\n/>\n\n<Modal bind:open title=\"Rename item\" {triggerRef}>\n  <Input id=\"modal-name\" bind:value={name} label=\"New name\" placeholder=\"Enter a name…\" autofocus />\n  {#snippet footer()}\n    <div style=\"display: flex; gap: 0.5rem; justify-content: flex-end;\">\n      <Button variant=\"secondary\" label=\"Cancel\" onclick={() => (open = false)} />\n      <Button variant=\"primary\" label=\"Save\" onclick={() => (open = false)} />\n    </div>\n  {/snippet}\n</Modal>\n"
    }
  ]
}
