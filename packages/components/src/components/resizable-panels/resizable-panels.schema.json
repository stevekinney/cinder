{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "panes": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "orientation": {
      "enum": ["horizontal", "vertical"]
    },
    "keyboardStep": {
      "type": "object"
    },
    "snapThreshold": {
      "type": "object"
    },
    "collapseOnDoubleClick": {
      "type": "boolean"
    },
    "collapseTarget": {
      "enum": ["leading", "trailing", "nearest-collapsible"]
    },
    "class": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "required": ["panes"]
}
