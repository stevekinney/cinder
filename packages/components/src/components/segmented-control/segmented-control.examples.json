{
  "$schema": "../../schemas/examples.schema.json",
  "component": "segmented-control",
  "import": "cinder/segmented-control",
  "examples": [
    {
      "id": "basic",
      "title": "Basic segmented control",
      "description": "A compact radio-group control with keyboard navigation.",
      "code": "<script lang=\"ts\">\n  import { Segment } from 'cinder/segment';\n  import { SegmentedControl } from 'cinder/segmented-control';\n\n  let value = $state('rendered');\n</script>\n\n<div style=\"display: grid; gap: 0.75rem; justify-items: start;\">\n  <SegmentedControl id=\"playground-view\" selectionMode=\"single\" bind:value label=\"Document view\">\n    <Segment value=\"source\">Source</Segment>\n    <Segment value=\"rendered\">Rendered</Segment>\n    <Segment value=\"diff\">Diff</Segment>\n  </SegmentedControl>\n  <p style=\"margin: 0; color: var(--cinder-text-muted);\">Current view: {value}</p>\n</div>\n"
    },
    {
      "id": "multiple",
      "title": "Multi-select segmented control",
      "description": "Multiple options can be toggled independently. Bind a SvelteSet to track selection.",
      "code": "<script lang=\"ts\">\n  import { SvelteSet } from 'svelte/reactivity';\n  import { Segment } from 'cinder/segment';\n  import { SegmentedControl } from 'cinder/segmented-control';\n\n  let formats = new SvelteSet<string>();\n\n  const selected = $derived([...formats].join(', ') || 'none');\n</script>\n\n<div style=\"display: grid; gap: 0.75rem; justify-items: start;\">\n  <SegmentedControl\n    id=\"playground-format\"\n    selectionMode=\"multiple\"\n    bind:value={formats}\n    label=\"Text formatting\"\n  >\n    <Segment value=\"bold\">Bold</Segment>\n    <Segment value=\"italic\">Italic</Segment>\n    <Segment value=\"underline\">Underline</Segment>\n    <Segment value=\"strikethrough\">Strike</Segment>\n  </SegmentedControl>\n  <p style=\"margin: 0; color: var(--cinder-text-muted);\">Active formats: {selected}</p>\n</div>\n"
    },
    {
      "id": "sizing",
      "title": "Sizing — size vs. toolbar density",
      "description": "Compares the three sizes (sm/md/lg) against `density=\"toolbar\"`. Toolbar density resolves to the same compact visual size as `size=\"sm\"` and ignores any explicit `size` value, so the toolbar-with-md and toolbar-with-lg controls render identically to the toolbar-without-size control and to `size=\"sm\"`.",
      "code": "<script lang=\"ts\">\n  import { Segment } from 'cinder/segment';\n  import { SegmentedControl } from 'cinder/segmented-control';\n\n  // Each control uses the same three options so size comparisons are not\n  // polluted by label/structure differences. The selected option is\n  // initialized to `rendered` (users can switch via click or keyboard) and\n  // `diff` is disabled so disabled-state styling is exercised on every\n  // control.\n  type View = 'source' | 'rendered' | 'diff';\n\n  let smValue = $state<View>('rendered');\n  let mdValue = $state<View>('rendered');\n  let lgValue = $state<View>('rendered');\n  let toolbarValue = $state<View>('rendered');\n  let toolbarMdValue = $state<View>('rendered');\n  let toolbarLgValue = $state<View>('rendered');\n</script>\n\n<div style=\"display: grid; gap: 1rem; justify-items: start;\">\n  <SegmentedControl\n    id=\"segmented-sizing-sm\"\n    selectionMode=\"single\"\n    size=\"sm\"\n    bind:value={smValue}\n    label=\"size=sm\"\n  >\n    <Segment value=\"source\">Source</Segment>\n    <Segment value=\"rendered\">Rendered</Segment>\n    <Segment value=\"diff\" disabled>Diff</Segment>\n  </SegmentedControl>\n\n  <SegmentedControl\n    id=\"segmented-sizing-md\"\n    selectionMode=\"single\"\n    size=\"md\"\n    bind:value={mdValue}\n    label=\"size=md (default)\"\n  >\n    <Segment value=\"source\">Source</Segment>\n    <Segment value=\"rendered\">Rendered</Segment>\n    <Segment value=\"diff\" disabled>Diff</Segment>\n  </SegmentedControl>\n\n  <SegmentedControl\n    id=\"segmented-sizing-lg\"\n    selectionMode=\"single\"\n    size=\"lg\"\n    bind:value={lgValue}\n    label=\"size=lg\"\n  >\n    <Segment value=\"source\">Source</Segment>\n    <Segment value=\"rendered\">Rendered</Segment>\n    <Segment value=\"diff\" disabled>Diff</Segment>\n  </SegmentedControl>\n\n  <SegmentedControl\n    id=\"segmented-sizing-toolbar\"\n    selectionMode=\"single\"\n    density=\"toolbar\"\n    bind:value={toolbarValue}\n    label=\"density=toolbar (no size)\"\n  >\n    <Segment value=\"source\">Source</Segment>\n    <Segment value=\"rendered\">Rendered</Segment>\n    <Segment value=\"diff\" disabled>Diff</Segment>\n  </SegmentedControl>\n\n  <SegmentedControl\n    id=\"segmented-sizing-toolbar-md\"\n    selectionMode=\"single\"\n    size=\"md\"\n    density=\"toolbar\"\n    bind:value={toolbarMdValue}\n    label=\"density=toolbar + size=md (size is ignored)\"\n  >\n    <Segment value=\"source\">Source</Segment>\n    <Segment value=\"rendered\">Rendered</Segment>\n    <Segment value=\"diff\" disabled>Diff</Segment>\n  </SegmentedControl>\n\n  <SegmentedControl\n    id=\"segmented-sizing-toolbar-lg\"\n    selectionMode=\"single\"\n    size=\"lg\"\n    density=\"toolbar\"\n    bind:value={toolbarLgValue}\n    label=\"density=toolbar + size=lg (size is ignored)\"\n  >\n    <Segment value=\"source\">Source</Segment>\n    <Segment value=\"rendered\">Rendered</Segment>\n    <Segment value=\"diff\" disabled>Diff</Segment>\n  </SegmentedControl>\n</div>\n"
    }
  ]
}
