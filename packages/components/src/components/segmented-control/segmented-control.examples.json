{
  "$schema": "../../schemas/examples.schema.json",
  "component": "segmented-control",
  "import": "@lostgradient/cinder/segmented-control",
  "examples": [
    {
      "id": "basic",
      "title": "Basic segmented control",
      "description": "A compact radio-group control with keyboard navigation.",
      "code": "<script lang=\"ts\">\n  import { Segment } from '@lostgradient/cinder/segment';\n  import { SegmentedControl } from '@lostgradient/cinder/segmented-control';\n\n  let value = $state('rendered');\n</script>\n\n<div style=\"display: grid; gap: 0.75rem; justify-items: start;\">\n  <SegmentedControl id=\"playground-view\" selectionMode=\"single\" bind:value label=\"Document view\">\n    <Segment value=\"source\">Source</Segment>\n    <Segment value=\"rendered\">Rendered</Segment>\n    <Segment value=\"diff\">Diff</Segment>\n  </SegmentedControl>\n  <p style=\"margin: 0; color: var(--cinder-text-muted);\">Current view: {value}</p>\n</div>\n"
    },
    {
      "id": "multiple",
      "title": "Multi-select segmented control",
      "description": "Multiple options can be toggled independently. Pass a SvelteSet to track selection.",
      "code": "<script lang=\"ts\">\n  import { SvelteSet } from 'svelte/reactivity';\n  import { Segment } from '@lostgradient/cinder/segment';\n  import { SegmentedControl } from '@lostgradient/cinder/segmented-control';\n\n  let formats = new SvelteSet<string>();\n\n  const selected = $derived([...formats].join(', ') || 'none');\n</script>\n\n<div style=\"display: grid; gap: 0.75rem; justify-items: start;\">\n  <SegmentedControl\n    id=\"playground-format\"\n    selectionMode=\"multiple\"\n    value={formats}\n    label=\"Text formatting\"\n  >\n    <Segment value=\"bold\">Bold</Segment>\n    <Segment value=\"italic\">Italic</Segment>\n    <Segment value=\"underline\">Underline</Segment>\n    <Segment value=\"strikethrough\">Strike</Segment>\n  </SegmentedControl>\n  <p style=\"margin: 0; color: var(--cinder-text-muted);\">Active formats: {selected}</p>\n</div>\n"
    },
    {
      "id": "navigation",
      "title": "Navigation route filters",
      "description": "Use the navigation variant with linked segments when each option should update the URL.",
      "code": "<script lang=\"ts\">\n  import { Segment } from '@lostgradient/cinder/segment';\n  import { SegmentedControl } from '@lostgradient/cinder/segmented-control';\n\n  const sources = [\n    { label: 'Actual', href: '/costs?source=actual', current: true },\n    { label: 'Forecast', href: '/costs?source=forecast' },\n    { label: 'Blended', href: '/costs?source=blended' },\n  ];\n</script>\n\n<SegmentedControl id=\"cost-source-filter\" label=\"Cost source\" variant=\"navigation\">\n  {#each sources as source (source.href)}\n    <Segment href={source.href} current={source.current}>{source.label}</Segment>\n  {/each}\n</SegmentedControl>\n"
    },
    {
      "id": "sizing",
      "title": "Sizing — size vs. toolbar density",
      "description": "Compares the three sizes (sm/md/lg) against `density=\"toolbar\"`. Toolbar density resolves to the same compact visual size as `size=\"sm\"` and ignores any explicit `size` value, so the toolbar-with-md and toolbar-with-lg controls render identically to the toolbar-without-size control and to `size=\"sm\"`.",
      "code": "<script lang=\"ts\">\n  import { Segment } from '@lostgradient/cinder/segment';\n  import { SegmentedControl } from '@lostgradient/cinder/segmented-control';\n\n  // Each control uses the same three options so size comparisons are not\n  // polluted by label/structure differences. The selected option is\n  // initialized to `rendered` (users can switch via click or keyboard) and\n  // `diff` is disabled so disabled-state styling is exercised on every\n  // control.\n  type View = 'source' | 'rendered' | 'diff';\n\n  let smValue = $state<View>('rendered');\n  let mdValue = $state<View>('rendered');\n  let lgValue = $state<View>('rendered');\n  let toolbarValue = $state<View>('rendered');\n  let toolbarMdValue = $state<View>('rendered');\n  let toolbarLgValue = $state<View>('rendered');\n</script>\n\n<div style=\"display: grid; gap: 1rem; justify-items: start;\">\n  <SegmentedControl\n    id=\"segmented-sizing-sm\"\n    selectionMode=\"single\"\n    size=\"sm\"\n    bind:value={smValue}\n    label=\"size=sm\"\n  >\n    <Segment value=\"source\">Source</Segment>\n    <Segment value=\"rendered\">Rendered</Segment>\n    <Segment value=\"diff\" disabled>Diff</Segment>\n  </SegmentedControl>\n\n  <SegmentedControl\n    id=\"segmented-sizing-md\"\n    selectionMode=\"single\"\n    size=\"md\"\n    bind:value={mdValue}\n    label=\"size=md (default)\"\n  >\n    <Segment value=\"source\">Source</Segment>\n    <Segment value=\"rendered\">Rendered</Segment>\n    <Segment value=\"diff\" disabled>Diff</Segment>\n  </SegmentedControl>\n\n  <SegmentedControl\n    id=\"segmented-sizing-lg\"\n    selectionMode=\"single\"\n    size=\"lg\"\n    bind:value={lgValue}\n    label=\"size=lg\"\n  >\n    <Segment value=\"source\">Source</Segment>\n    <Segment value=\"rendered\">Rendered</Segment>\n    <Segment value=\"diff\" disabled>Diff</Segment>\n  </SegmentedControl>\n\n  <SegmentedControl\n    id=\"segmented-sizing-toolbar\"\n    selectionMode=\"single\"\n    density=\"toolbar\"\n    bind:value={toolbarValue}\n    label=\"density=toolbar (no size)\"\n  >\n    <Segment value=\"source\">Source</Segment>\n    <Segment value=\"rendered\">Rendered</Segment>\n    <Segment value=\"diff\" disabled>Diff</Segment>\n  </SegmentedControl>\n\n  <SegmentedControl\n    id=\"segmented-sizing-toolbar-md\"\n    selectionMode=\"single\"\n    size=\"md\"\n    density=\"toolbar\"\n    bind:value={toolbarMdValue}\n    label=\"density=toolbar + size=md (size is ignored)\"\n  >\n    <Segment value=\"source\">Source</Segment>\n    <Segment value=\"rendered\">Rendered</Segment>\n    <Segment value=\"diff\" disabled>Diff</Segment>\n  </SegmentedControl>\n\n  <SegmentedControl\n    id=\"segmented-sizing-toolbar-lg\"\n    selectionMode=\"single\"\n    size=\"lg\"\n    density=\"toolbar\"\n    bind:value={toolbarLgValue}\n    label=\"density=toolbar + size=lg (size is ignored)\"\n  >\n    <Segment value=\"source\">Source</Segment>\n    <Segment value=\"rendered\">Rendered</Segment>\n    <Segment value=\"diff\" disabled>Diff</Segment>\n  </SegmentedControl>\n</div>\n"
    },
    {
      "id": "tablist",
      "title": "Tablist variant",
      "description": "The `variant=\"tablist\"` treatment for picker-shaped controls that switch between externally owned panels. Unlike the default radiogroup, the tablist has no enclosing surface and marks the selected tab with an accent underline (horizontal) or inline-start bar (vertical). Each tab wires `aria-controls` to a panel rendered elsewhere in the layout. See docs/decisions/segmented-control-tablist-variant.md.",
      "code": "<script lang=\"ts\">\n  import { Segment } from '@lostgradient/cinder/segment';\n  import { SegmentedControl } from '@lostgradient/cinder/segmented-control';\n\n  type View = 'editor' | 'diff' | 'summary';\n\n  const views: { value: View; label: string; body: string }[] = [\n    { value: 'editor', label: 'Editor', body: 'Editor panel — edit the document here.' },\n    { value: 'diff', label: 'Diff', body: 'Diff panel — review the changes side by side.' },\n    { value: 'summary', label: 'Summary', body: 'Summary panel — the high-level overview.' },\n  ];\n\n  let horizontalValue = $state<View>('editor');\n  let verticalValue = $state<View>('editor');\n</script>\n\n<div style=\"display: grid; gap: 1.5rem; justify-items: start;\">\n  <div style=\"display: grid; gap: 0.75rem; justify-items: start; width: 100%;\">\n    <SegmentedControl\n      id=\"segmented-tablist-horizontal\"\n      selectionMode=\"single\"\n      variant=\"tablist\"\n      bind:value={horizontalValue}\n      label=\"Review view\"\n    >\n      {#each views as view (view.value)}\n        <Segment\n          id=\"segmented-tablist-{view.value}-tab\"\n          value={view.value}\n          controls=\"segmented-tablist-{view.value}-panel\"\n        >\n          {view.label}\n        </Segment>\n      {/each}\n    </SegmentedControl>\n\n    {#each views as view (view.value)}\n      <div\n        id=\"segmented-tablist-{view.value}-panel\"\n        role=\"tabpanel\"\n        aria-labelledby=\"segmented-tablist-{view.value}-tab\"\n        hidden={horizontalValue !== view.value}\n        style=\"color: var(--cinder-text-muted);\"\n      >\n        {view.body}\n      </div>\n    {/each}\n  </div>\n\n  <div style=\"display: grid; gap: 0.75rem; justify-items: start; width: 100%;\">\n    <SegmentedControl\n      id=\"segmented-tablist-vertical\"\n      selectionMode=\"single\"\n      variant=\"tablist\"\n      orientation=\"vertical\"\n      bind:value={verticalValue}\n      label=\"Review view (vertical)\"\n    >\n      {#each views as view (view.value)}\n        <Segment\n          id=\"segmented-tablist-v-{view.value}-tab\"\n          value={view.value}\n          controls=\"segmented-tablist-v-{view.value}-panel\"\n        >\n          {view.label}\n        </Segment>\n      {/each}\n    </SegmentedControl>\n\n    {#each views as view (view.value)}\n      <div\n        id=\"segmented-tablist-v-{view.value}-panel\"\n        role=\"tabpanel\"\n        aria-labelledby=\"segmented-tablist-v-{view.value}-tab\"\n        hidden={verticalValue !== view.value}\n        style=\"color: var(--cinder-text-muted);\"\n      >\n        {view.body}\n      </div>\n    {/each}\n  </div>\n</div>\n"
    }
  ]
}
