{
  "name": "@lostgradient/chat",
  "version": "0.1.1",
  "description": "An accessible Svelte 5 conversation surface built on Conversationalist and Cinder.",
  "keywords": [
    "svelte",
    "svelte-5",
    "chat",
    "conversation",
    "ai",
    "accessibility"
  ],
  "homepage": "https://github.com/stevekinney/cinder#readme",
  "bugs": {
    "url": "https://github.com/stevekinney/cinder/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stevekinney/cinder.git",
    "directory": "packages/chat"
  },
  "license": "MIT",
  "author": "Steve Kinney <hello@stevekinney.net>",
  "sideEffects": [
    "**/*.css"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./src/lib/index.ts",
      "node": "./dist/server/index.js",
      "svelte": "./src/lib/index.ts",
      "import": "./src/lib/index.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json",
    "./manifest": "./components.json",
    "./schema": {
      "types": "./dist/components/chat/chat.schema.d.ts",
      "browser": "./src/lib/components/chat/chat.schema.ts",
      "svelte": "./src/lib/components/chat/chat.schema.ts",
      "import": "./src/lib/components/chat/chat.schema.ts",
      "default": "./dist/components/chat/chat.schema.js"
    },
    "./variables": {
      "types": "./dist/components/chat/chat.variables.d.ts",
      "browser": "./src/lib/components/chat/chat.variables.ts",
      "svelte": "./src/lib/components/chat/chat.variables.ts",
      "import": "./src/lib/components/chat/chat.variables.ts",
      "default": "./dist/components/chat/chat.variables.js"
    },
    "./styles": {
      "types": "./dist/components/chat/chat.css.d.ts",
      "default": "./dist/components/chat/chat.css"
    },
    "./examples": "./dist/components/chat/chat.examples.json",
    "./composer-popover": {
      "types": "./dist/components/chat-composer-popover/index.d.ts",
      "browser": "./src/lib/components/chat-composer-popover/index.ts",
      "node": "./dist/server/components/chat-composer-popover/index.js",
      "svelte": "./src/lib/components/chat-composer-popover/index.ts",
      "import": "./src/lib/components/chat-composer-popover/index.ts",
      "default": "./dist/components/chat-composer-popover/index.js"
    },
    "./composer-popover/schema": {
      "types": "./dist/components/chat-composer-popover/chat-composer-popover.schema.d.ts",
      "browser": "./src/lib/components/chat-composer-popover/chat-composer-popover.schema.ts",
      "svelte": "./src/lib/components/chat-composer-popover/chat-composer-popover.schema.ts",
      "import": "./src/lib/components/chat-composer-popover/chat-composer-popover.schema.ts",
      "default": "./dist/components/chat-composer-popover/chat-composer-popover.schema.js"
    },
    "./composer-popover/variables": {
      "types": "./dist/components/chat-composer-popover/chat-composer-popover.variables.d.ts",
      "browser": "./src/lib/components/chat-composer-popover/chat-composer-popover.variables.ts",
      "svelte": "./src/lib/components/chat-composer-popover/chat-composer-popover.variables.ts",
      "import": "./src/lib/components/chat-composer-popover/chat-composer-popover.variables.ts",
      "default": "./dist/components/chat-composer-popover/chat-composer-popover.variables.js"
    },
    "./composer-popover/styles": {
      "types": "./dist/components/chat-composer-popover/chat-composer-popover.css.d.ts",
      "default": "./dist/components/chat-composer-popover/chat-composer-popover.css"
    },
    "./composer-popover/examples": "./dist/components/chat-composer-popover/chat-composer-popover.examples.json",
    "./conversation-header": {
      "types": "./dist/components/chat-conversation-header/index.d.ts",
      "browser": "./src/lib/components/chat-conversation-header/index.ts",
      "node": "./dist/server/components/chat-conversation-header/index.js",
      "svelte": "./src/lib/components/chat-conversation-header/index.ts",
      "import": "./src/lib/components/chat-conversation-header/index.ts",
      "default": "./dist/components/chat-conversation-header/index.js"
    },
    "./conversation-header/schema": {
      "types": "./dist/components/chat-conversation-header/chat-conversation-header.schema.d.ts",
      "browser": "./src/lib/components/chat-conversation-header/chat-conversation-header.schema.ts",
      "svelte": "./src/lib/components/chat-conversation-header/chat-conversation-header.schema.ts",
      "import": "./src/lib/components/chat-conversation-header/chat-conversation-header.schema.ts",
      "default": "./dist/components/chat-conversation-header/chat-conversation-header.schema.js"
    },
    "./conversation-header/variables": {
      "types": "./dist/components/chat-conversation-header/chat-conversation-header.variables.d.ts",
      "browser": "./src/lib/components/chat-conversation-header/chat-conversation-header.variables.ts",
      "svelte": "./src/lib/components/chat-conversation-header/chat-conversation-header.variables.ts",
      "import": "./src/lib/components/chat-conversation-header/chat-conversation-header.variables.ts",
      "default": "./dist/components/chat-conversation-header/chat-conversation-header.variables.js"
    },
    "./conversation-header/styles": {
      "types": "./dist/components/chat-conversation-header/chat-conversation-header.css.d.ts",
      "default": "./dist/components/chat-conversation-header/chat-conversation-header.css"
    },
    "./conversation-header/examples": "./dist/components/chat-conversation-header/chat-conversation-header.examples.json",
    "./conversation-list": {
      "types": "./dist/components/chat-conversation-list/index.d.ts",
      "browser": "./src/lib/components/chat-conversation-list/index.ts",
      "node": "./dist/server/components/chat-conversation-list/index.js",
      "svelte": "./src/lib/components/chat-conversation-list/index.ts",
      "import": "./src/lib/components/chat-conversation-list/index.ts",
      "default": "./dist/components/chat-conversation-list/index.js"
    },
    "./conversation-list/schema": {
      "types": "./dist/components/chat-conversation-list/chat-conversation-list.schema.d.ts",
      "browser": "./src/lib/components/chat-conversation-list/chat-conversation-list.schema.ts",
      "svelte": "./src/lib/components/chat-conversation-list/chat-conversation-list.schema.ts",
      "import": "./src/lib/components/chat-conversation-list/chat-conversation-list.schema.ts",
      "default": "./dist/components/chat-conversation-list/chat-conversation-list.schema.js"
    },
    "./conversation-list/variables": {
      "types": "./dist/components/chat-conversation-list/chat-conversation-list.variables.d.ts",
      "browser": "./src/lib/components/chat-conversation-list/chat-conversation-list.variables.ts",
      "svelte": "./src/lib/components/chat-conversation-list/chat-conversation-list.variables.ts",
      "import": "./src/lib/components/chat-conversation-list/chat-conversation-list.variables.ts",
      "default": "./dist/components/chat-conversation-list/chat-conversation-list.variables.js"
    },
    "./conversation-list/styles": {
      "types": "./dist/components/chat-conversation-list/chat-conversation-list.css.d.ts",
      "default": "./dist/components/chat-conversation-list/chat-conversation-list.css"
    },
    "./conversation-list/examples": "./dist/components/chat-conversation-list/chat-conversation-list.examples.json"
  },
  "svelte": "./dist/index.js",
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.fixture.*",
    "!dist/**/*-fixture.*",
    "!dist/**/*-fixtures.*",
    "!dist/**/test/**",
    "components.json"
  ],
  "scripts": {
    "build": "bun run scripts/build.ts",
    "clean": "rm -rf dist coverage node_modules/.cache lostgradient-chat-*.tgz",
    "colors:audit": "bun ../components/scripts/check-component-css-raw-colors.ts --source-root src/lib --baseline scripts/raw-color-baseline.json --strict",
    "components:check": "bun run scripts/generate-component-artifacts.ts --check",
    "components:generate": "bun run scripts/generate-component-artifacts.ts",
    "dev": "svelte-package --watch",
    "lint": "oxlint --type-aware --tsconfig tsconfig.json $(rg --files src scripts -g '*.ts' -g '*.svelte')",
    "lint:fix": "oxlint --fix --type-aware --tsconfig tsconfig.json $(rg --files src scripts -g '*.ts' -g '*.svelte')",
    "pack:publish": "bun run scripts/pack-for-publish.ts",
    "package:weight:check": "bun ../components/scripts/report-package-weight.ts --check --package-root .",
    "platform:audit": "bun ../components/scripts/check-platform-features.ts --source-root src/lib --baseline scripts/platform-viewport-baseline.json --strict",
    "publish:release": "bun ../components/scripts/publish-release.ts --package-root .",
    "test": "TZ=UTC LANG=en_US.UTF-8 bun test --conditions browser --conditions svelte --parallel=1 src/lib scripts",
    "test:coverage": "TZ=UTC LANG=en_US.UTF-8 bun test --conditions browser --conditions svelte --parallel=1 src/lib scripts --coverage --coverage-reporter=lcov && bun ../components/scripts/check-coverage-ratchet.ts --package-root .",
    "tokens:audit": "bun ../components/scripts/check-component-css-token-usage.ts --source-root src/lib --baseline scripts/token-usage-baseline.json --strict",
    "typecheck": "tsc --noEmit -p tsconfig.json && bunx svelte-check --workspace src/lib --tsconfig ../../tsconfig.json --threshold warning",
    "validate": "bun run lint && bun run typecheck && bun run test:coverage && bun run platform:audit && bun run colors:audit && bun run tokens:audit && bun run components:check && bun run build",
    "validate:consumer": "bun run scripts/validate-consumer.ts"
  },
  "dependencies": {
    "conversationalist": "^0.2.1 || ^0.4.1",
    "zod": "4.4.1"
  },
  "devDependencies": {
    "@lostgradient/cinder": "workspace:*",
    "@sveltejs/package": "^2.5.8",
    "@testing-library/svelte": "^5.2.7",
    "@types/bun": "^1.3.11",
    "ajv": "^8",
    "happy-dom": "^15.11.7",
    "oxlint": "^1.56.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.1",
    "svelte": "~5.56.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.9.0"
  },
  "peerDependencies": {
    "@lostgradient/cinder": "^0.17.0",
    "svelte": ">=5.56.0 <6"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": false
  }
}
