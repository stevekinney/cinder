{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "bunVersion": "1.x",
  "framework": null,
  "buildCommand": "bun run vercel-build",
  "installCommand": "cd ../.. && bun install --frozen-lockfile",
  "outputDirectory": "public",
  "functions": {
    "src/server.ts": {
      "includeFiles": "../components/{src,scripts}/**",
      "maxDuration": 60
    }
  }
}
