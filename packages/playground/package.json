{
  "name": "@cinder/playground",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch run src/server.ts",
    "lint": "oxlint src/",
    "lint:fix": "oxlint --fix src/",
    "test": "TZ=UTC LANG=en_US.UTF-8 bun test --conditions browser",
    "typecheck": "tsc --noEmit && bunx svelte-check --tsconfig tsconfig.json --threshold error",
    "validate": "bun run src/validate-playground.ts"
  },
  "dependencies": {
    "cinder": "workspace:*",
    "shiki": "^3.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "svelte": "~5.55.0",
    "svelte-check": "^4.0.0",
    "ts-morph": "^28.0.0",
    "typescript": "^5.9.0"
  }
}
