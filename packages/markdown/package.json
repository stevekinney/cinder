{
  "name": "@lostgradient/markdown",
  "version": "0.0.0",
  "description": "Headless Markdown pipeline, rendering, diffing, and templating for Cinder and its sibling packages.",
  "keywords": [
    "markdown",
    "remark",
    "rehype",
    "unified",
    "diff",
    "templates"
  ],
  "homepage": "https://github.com/stevekinney/cinder#readme",
  "bugs": {
    "url": "https://github.com/stevekinney/cinder/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stevekinney/cinder.git",
    "directory": "packages/markdown"
  },
  "license": "MIT",
  "author": "Steve Kinney <hello@stevekinney.net>",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json",
    "./pipeline": {
      "types": "./dist/pipeline/index.d.ts",
      "bun": "./src/pipeline/index.ts",
      "import": "./dist/pipeline/index.js",
      "default": "./dist/pipeline/index.js"
    },
    "./diff": {
      "types": "./dist/diff/index.d.ts",
      "bun": "./src/diff/index.ts",
      "import": "./dist/diff/index.js",
      "default": "./dist/diff/index.js"
    },
    "./diff/line-diff": {
      "types": "./dist/diff/line-diff.d.ts",
      "bun": "./src/diff/line-diff.ts",
      "import": "./dist/diff/line-diff.js",
      "default": "./dist/diff/line-diff.js"
    },
    "./diff/types": {
      "types": "./dist/diff/types.d.ts",
      "bun": "./src/diff/types.ts",
      "import": "./dist/diff/types.js",
      "default": "./dist/diff/types.js"
    },
    "./rendering": {
      "types": "./dist/rendering/index.d.ts",
      "bun": "./src/rendering/index.ts",
      "import": "./dist/rendering/index.js",
      "default": "./dist/rendering/index.js"
    },
    "./rendering/async": {
      "types": "./dist/rendering/async.d.ts",
      "bun": "./src/rendering/async.ts",
      "import": "./dist/rendering/async.js",
      "default": "./dist/rendering/async.js"
    },
    "./rendering/types": {
      "types": "./dist/rendering/types.d.ts",
      "bun": "./src/rendering/types.ts",
      "import": "./dist/rendering/types.js",
      "default": "./dist/rendering/types.js"
    },
    "./rendering/highlighter": {
      "types": "./dist/rendering/highlighter.d.ts",
      "bun": "./src/rendering/highlighter.ts",
      "import": "./dist/rendering/highlighter.js",
      "default": "./dist/rendering/highlighter.js"
    },
    "./rendering/mermaid-cache": {
      "types": "./dist/rendering/mermaid-cache.d.ts",
      "bun": "./src/rendering/mermaid-cache.ts",
      "import": "./dist/rendering/mermaid-cache.js",
      "default": "./dist/rendering/mermaid-cache.js"
    },
    "./utilities/safe-url": {
      "types": "./dist/utilities/safe-url.d.ts",
      "bun": "./src/utilities/safe-url.ts",
      "import": "./dist/utilities/safe-url.js",
      "default": "./dist/utilities/safe-url.js"
    },
    "./utilities/sort-keys": {
      "types": "./dist/utilities/sort-keys.d.ts",
      "bun": "./src/utilities/sort-keys.ts",
      "import": "./dist/utilities/sort-keys.js",
      "default": "./dist/utilities/sort-keys.js"
    },
    "./templates/sanitize-html": {
      "types": "./dist/templates/sanitize-html.d.ts",
      "bun": "./src/templates/sanitize-html.ts",
      "import": "./dist/templates/sanitize-html.js",
      "default": "./dist/templates/sanitize-html.js"
    },
    "./templates/template-placeholders": {
      "types": "./dist/templates/template-placeholders.d.ts",
      "bun": "./src/templates/template-placeholders.ts",
      "import": "./dist/templates/template-placeholders.js",
      "default": "./dist/templates/template-placeholders.js"
    },
    "./templates/template-render": {
      "types": "./dist/templates/template-render.d.ts",
      "bun": "./src/templates/template-render.ts",
      "import": "./dist/templates/template-render.js",
      "default": "./dist/templates/template-render.js"
    },
    "./templates/placeholder-security": {
      "types": "./dist/templates/placeholder-security.d.ts",
      "bun": "./src/templates/placeholder-security.ts",
      "import": "./dist/templates/placeholder-security.js",
      "default": "./dist/templates/placeholder-security.js"
    },
    "./templates/types": {
      "types": "./dist/templates/types.d.ts",
      "bun": "./src/templates/types.ts",
      "import": "./dist/templates/types.js",
      "default": "./dist/templates/types.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*",
    "!dist/**/*.fixture.*",
    "!dist/**/*-fixture.*",
    "!dist/**/*-fixtures.*",
    "!dist/**/test/**",
    "!dist/**/*.map",
    "README.md"
  ],
  "scripts": {
    "build": "bun run scripts/build.ts",
    "clean": "rm -rf dist coverage node_modules/.cache lostgradient-markdown-*.tgz",
    "lint": "oxlint --type-aware --tsconfig ./tsconfig.json",
    "lint:fix": "oxlint --fix --type-aware --tsconfig ./tsconfig.json",
    "pack:publish": "bun run scripts/pack-for-publish.ts",
    "package:weight:check": "bun ../components/scripts/report-package-weight.ts --check --package-root .",
    "publish:release": "bun ../components/scripts/publish-release.ts --package-root .",
    "test": "TZ=UTC LANG=en_US.UTF-8 bun test",
    "typecheck": "tsc --noEmit -p tsconfig.check.json",
    "validate": "bun run lint && bun run typecheck && bun run test && bun run build",
    "validate:consumer": "bun run scripts/validate-consumer.ts"
  },
  "dependencies": {
    "@shikijs/engine-oniguruma": "^3.21.0",
    "@shikijs/langs": "^3.21.0",
    "@shikijs/types": "^3.21.0",
    "@types/mdast": "^4.0.4",
    "@types/unist": "^3.0.0",
    "comlink": "^4.4.2",
    "diff-match-patch": "^1.0.5",
    "hast-util-sanitize": "^5.0.0",
    "js-yaml": "^4.1.0",
    "rehype-katex": "^7.0.1",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "remark-stringify": "^11.0.0",
    "shiki": "^3.21.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/diff-match-patch": "^1.0.36",
    "@types/hast": "^3.0.4",
    "@types/js-yaml": "^4.0.9",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.17.0",
    "typescript": "^5.9.0"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": false
  }
}
